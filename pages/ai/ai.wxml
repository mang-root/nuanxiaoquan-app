<view class="ai-page">

<!-- 顶部欢迎区 -->
<view class="ai-header">
  <view class="ai-avatar">✨</view>
  <view class="ai-header-info">
    <text class="ai-name">小暖</text>
    <text class="ai-desc">学习规划 · 记账分析 · 生活助手</text>
  </view>
  <view class="clear-btn" bindtap="clearChat" wx:if="{{messages.length > 0}}">清空</view>
</view>

<!-- 快捷功能卡片（未开始对话时显示） -->
<view class="quick-cards" wx:if="{{messages.length === 0}}">
  <view class="qc-title">你可以问我：</view>
  <view class="qc-list">
    <view class="qc-card" bindtap="quickAsk" data-q="帮我制定一个考研30天备考计划，我主要需要准备政治和英语">
      <text class="qc-icon">📅</text>
      <text class="qc-text">制定学习计划</text>
    </view>
    <view class="qc-card" bindtap="quickAsk" data-q="帮我分析一下我的收支情况，上个月餐饮300元，购物500元，娱乐200元，收入生活费2000元">
      <text class="qc-icon">💰</text>
      <text class="qc-text">记账收支分析</text>
    </view>
    <view class="qc-card" bindtap="quickAsk" data-q="帮我推荐一些四六级高效备考方法和学习技巧">
      <text class="qc-icon">📖</text>
      <text class="qc-text">学习方法推荐</text>
    </view>
    <view class="qc-card" bindtap="quickAsk" data-q="我最近学习效率很低，帮我分析原因和改进建议">
      <text class="qc-icon">🧠</text>
      <text class="qc-text">学习效率分析</text>
    </view>
  </view>
</view>

<!-- 对话列表 -->
<scroll-view class="chat-list" scroll-y="true" scroll-into-view="{{scrollId}}" scroll-with-animation="true">
  <view wx:for="{{messages}}" wx:key="id" id="msg-{{item.id}}">

    <!-- 用户消息 -->
    <view wx:if="{{item.role === 'user'}}" class="msg-row user-row">
      <view class="user-bubble">{{item.content}}</view>
      <view class="user-avatar">我</view>
    </view>

    <!-- AI消息 -->
    <view wx:if="{{item.role === 'assistant'}}" class="msg-row ai-row">
      <view class="ai-bubble-avatar">✨</view>
      <view class="ai-bubble">
        <text wx:if="{{item.loading}}" class="ai-loading">思考中...</text>
        <text wx:else class="ai-content">{{item.content}}</text>
      </view>
    </view>

  </view>
  <view style="height: 32rpx;"></view>
</scroll-view>

<!-- 一键导入学习计划提示 -->
<view class="import-bar" wx:if="{{importPlanShow}}">
  <text class="import-tip">✦ 检测到学习计划，可一键导入到知时</text>
  <view class="import-actions">
    <view class="import-btn" bindtap="importToPlan">导入计划</view>
    <view class="import-dismiss" bindtap="dismissImport">✕</view>
  </view>
</view>

<!-- 输入区 -->
<view class="input-area">
  <textarea
    class="chat-input"
    placeholder="问我任何问题..."
    value="{{inputText}}"
    bindinput="onInput"
    auto-height
    maxlength="500"
  />
  <view class="send-btn {{inputText.trim() ? 'active' : ''}}" bindtap="sendMessage">
    <text>发送</text>
  </view>
</view>

</view>
