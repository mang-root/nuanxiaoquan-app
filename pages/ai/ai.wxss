/* pages/ai/ai.wxss */
page {
  background: #FAFAFA;
  height: 100vh;
  display: flex;
  flex-direction: column;
}
.ai-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FAFAFA;
}

.ai-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFE8F0, #F0F4FF);
  border-bottom: 1rpx solid #F0F0F0;
}
.ai-avatar {
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF8DA8, #A8C7FA);
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx;
}
.ai-name { font-size: 28rpx; font-weight: 700; color: #333; display: block; }
.ai-desc { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }

.quick-cards {
  padding: 24rpx;
}
.qc-title { font-size: 26rpx; color: #999; margin-bottom: 16rpx; }
.qc-list { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.qc-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  display: flex; flex-direction: column; align-items: center; gap: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.qc-icon { font-size: 48rpx; }
.qc-text { font-size: 24rpx; color: #555; text-align: center; }

.chat-list {
  flex: 1;
  padding: 16rpx;
  overflow-y: auto;
}

.msg-row {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.user-row { justify-content: flex-end; }
.ai-row { justify-content: flex-start; }

.user-bubble {
  max-width: 70%;
  background: linear-gradient(135deg, #FF8DA8, #FF6B99);
  color: #fff;
  border-radius: 24rpx 24rpx 6rpx 24rpx;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
}
.user-avatar {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: #FFD4DF;
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; color: #FF8DA8; font-weight: 700;
  flex-shrink: 0;
}

.ai-bubble-avatar {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF8DA8, #A8C7FA);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}
.ai-bubble {
  max-width: 75%;
  background: #fff;
  border-radius: 6rpx 24rpx 24rpx 24rpx;
  padding: 18rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.ai-content { font-size: 28rpx; color: #333; line-height: 1.7; white-space: pre-wrap; }
.ai-loading { font-size: 28rpx; color: #999; }

.input-area {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: #fff;
  border-top: 1rpx solid #F0F0F0;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}
.chat-input {
  flex: 1;
  background: #F5F5F5;
  border-radius: 20rpx;
  padding: 14rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  max-height: 200rpx;
  min-height: 72rpx;
}
.send-btn {
  background: #E0E0E0;
  border-radius: 20rpx;
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  color: #fff;
  flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  height: 72rpx;
  box-sizing: border-box;
}
.send-btn.active {
  background: linear-gradient(135deg, #FF8DA8, #FF6B99);
}

/* 清空按钮 */
.ai-header-info { flex: 1; }
.clear-btn { font-size: 24rpx; color: #bbb; padding: 8rpx 16rpx; }

/* 导入计划提示条 */
.import-bar {
  background: linear-gradient(135deg, #e8f4ff, #f0e8ff);
  padding: 18rpx 24rpx;
  display: flex; align-items: center; justify-content: space-between;
  border-top: 1rpx solid #e0eaff;
}
.import-tip { font-size: 24rpx; color: #5b7dcc; flex: 1; }
.import-actions { display: flex; align-items: center; gap: 16rpx; }
.import-btn {
  background: #5b7dcc; color: #fff; border-radius: 20rpx;
  padding: 10rpx 24rpx; font-size: 24rpx;
}
.import-dismiss { font-size: 28rpx; color: #aaa; padding: 4rpx 8rpx; }
