/* pages/mine/setting/setting.wxss */

.setting-page {
  background: #F7F7F7;
  min-height: 100vh;
  padding-bottom: 48rpx;
}

.section-title {
  padding: 32rpx 32rpx 12rpx;
  font-size: 24rpx;
  color: #999999;
}

.group {
  background: #FFFFFF;
  margin: 0 16rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.row {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}
.row:last-child {
  border-bottom: none;
}
.row-main {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.row-label {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
}
.row-sub {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}
.row-value {
  font-size: 26rpx;
  color: #999999;
  margin-right: 12rpx;
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.row-arrow {
  color: #CCCCCC;
  font-size: 32rpx;
}
.color-preview {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  border: 2rpx solid #F0F0F0;
}
.danger-text {
  color: #E57373;
}

/* 性别选择样式 */
.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.item-label {
  font-size: 28rpx;
  color: #333;
}
.picker-text {
  font-size: 26rpx;
  color: #999;
  margin-right: 12rpx;
}
.arrow {
  font-size: 24rpx;
  color: #ccc;
}

.row-value-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #999;
  font-size: 26rpx;
}
.row-sub-inline {
  flex: 1;
  font-size: 20rpx;
  color: #999;
  margin-left: 8rpx;
}
.row-sub-inline.danger-text {
  color: #e57373;
}

.row-nickname-input {
  flex: 1;
  font-size: 26rpx;
  color: #999;
  text-align: right;
  padding-right: 8rpx;
}

.theme-switch {
  display: flex;
  gap: 12rpx;
}
.theme-btn {
  padding: 10rpx 24rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
}
.active-female {
  background: #ffe8f0;
  color: #ff8da8;
}
.active-male {
  background: #e8f1fa;
  color: #5b8db8;
}
