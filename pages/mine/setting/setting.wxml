<!-- pages/mine/setting/setting.wxml -->
<view class="setting-page">

<!-- 个人资料 -->
<view class="section-title">个人资料</view>
<view class="group">
  <view class="row">
    <text class="row-label">昵称</text>
    <input
      class="row-nickname-input"
      type="nickname"
      placeholder="点击修改昵称"
      value="{{userInfo.nickname}}"
      bindblur="onNicknameBlur"
      maxlength="20"
      focus="{{autoFocus === 'nickname'}}"
    />
    <text class="row-arrow">›</text>
  </view>
  <view class="row" bindtap="editSignature">
    <text class="row-label">个性签名</text>
    <text class="row-value">{{userInfo.signature || '未填写'}}</text>
    <text class="row-arrow">›</text>
  </view>
  <view class="row" bindtap="changeAvatarColor">
    <text class="row-label">头像配色</text>
    <view class="color-preview" style="background: {{userInfo.avatarColor}};"></view>
    <text class="row-arrow">›</text>
  </view>
  <view class="row">
    <text class="row-label">性别</text>
    <picker mode="selector" range="{{genderOptions}}" bindchange="onGenderChange" value="{{genderIndex}}">
      <view class="row-value-picker">
        <text>{{gender || '未设置'}}</text>
        <text class="row-arrow">›</text>
      </view>
    </picker>
  </view>
</view>

<!-- 外观（你要求添加的） -->
<view class="section-title">外观</view>
<view class="group">
  <view class="row">
    <text class="row-label">主题风格</text>
    <view class="theme-switch">
      <view class="theme-btn {{userGender === 'female' ? 'active-female' : ''}}" bindtap="setTheme" data-gender="female">女生</view>
      <view class="theme-btn {{userGender === 'male' ? 'active-male' : ''}}" bindtap="setTheme" data-gender="male">男生</view>
    </view>
  </view>
</view>

<!-- 模式管理 -->
<view class="section-title">模式管理</view>
<view class="group">
  <view class="row">
    <view class="row-main">
      <text class="row-label">生理期模式</text>
      <text class="row-sub">开启后,在「知时」可切换到生理期记录</text>
    </view>
    <switch checked="{{showPeriodMode}}" bindchange="togglePeriod" color="#FF8DA8" />
  </view>
</view>

<!-- 关于 -->
<view class="section-title">关于</view>
<view class="group">
  <view class="row" bindtap="feedbackEmail">
    <text class="row-label">意见反馈</text>
    <text class="row-arrow">›</text>
  </view>
  <view class="row" bindtap="aboutUs">
    <text class="row-label">关于暖小圈</text>
    <text class="row-arrow">›</text>
  </view>
  <view class="row" bindtap="userAgreement">
    <text class="row-label">用户协议</text>
    <text class="row-arrow">›</text>
  </view>
  <view class="row" bindtap="privacyPolicy">
    <text class="row-label">隐私政策</text>
    <text class="row-arrow">›</text>
  </view>
</view>

<!-- 数据 -->
<view class="section-title">数据</view>
<view class="group">
  <view class="row" bindtap="clearTempCache">
    <text class="row-label">清除缓存</text>
    <text class="row-sub-inline">只清理临时数据,不影响帖子和记录</text>
    <text class="row-arrow">›</text>
  </view>
  <view class="row danger-row" bindtap="clearAllData">
    <text class="row-label danger-text">清除全部数据</text>
    <text class="row-sub-inline danger-text">帖子、任务、账单等全部清空</text>
    <text class="row-arrow">›</text>
  </view>
</view>

<view style="height: 60rpx;"></view>
</view>