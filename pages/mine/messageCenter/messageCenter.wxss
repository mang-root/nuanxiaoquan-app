/* pages/mine/messageCenter/messageCenter.wxss */

.msg-page {
  background: #F7F7F7;
  min-height: 100vh;
}

.tabs {
  display: flex;
  background: #FFFFFF;
  padding: 0 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #999999;
  position: relative;
}
.tab.active {
  color: #333333;
  font-weight: 600;
}
.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #FF8DA8;
  border-radius: 2rpx;
}

.content {
  padding: 16rpx;
}
.msg-item {
  display: flex;
  align-items: flex-start;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
  position: relative;
}
.msg-dot {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #FF8DA8;
}
.msg-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.msg-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6rpx;
}
.msg-desc {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 6rpx;
}
.msg-time {
  font-size: 20rpx;
  color: #999999;
}

.clear-btn {
  position: fixed;
  right: 32rpx;
  bottom: 48rpx;
  padding: 16rpx 24rpx;
  background: #FFFFFF;
  color: #666666;
  border-radius: 100rpx;
  font-size: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.empty-state {
  padding: 200rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.empty-emoji {
  font-size: 72rpx;
  margin-bottom: 12rpx;
}
.empty-text {
  font-size: 26rpx;
  color: #999999;
}
