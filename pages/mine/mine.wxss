/* pages/mine/mine.wxss */
.mine-page {
  background: #FAFAFA;
  min-height: 100vh;
}

.top-section {
  background: linear-gradient(180deg, #FFE8F0 0%, #FFF5F7 100%);
  padding: 88rpx 24rpx 32rpx;
  position: relative;
}
.top-actions {
  position: absolute;
  top: 32rpx;
  right: 24rpx;
  display: flex;
  gap: 12rpx;
}
.top-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
}
.top-icon { font-size: 32rpx; }

.avatar-fix-wrapper {
  display: flex;
  align-items: center;
  width: auto !important;
  flex-shrink: 0;
}
.user-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.avatar-big-btn {
  margin: 0 !important;
  padding: 0 !important;
  background: transparent !important;
  border: 0 !important;
  width: 100rpx !important;
  height: 100rpx !important;
  border-radius: 50% !important;
  overflow: hidden;
}
.avatar-big {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #FF8DA8;
}
.avatar-real {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}
.avatar-letter { font-size: 36rpx; color: #fff; font-weight: 700; }

.user-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.nickname { font-size: 32rpx; font-weight: 700; color: #333; }
.sign { font-size: 24rpx; color: #888; }

.level-card {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.85);
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  gap: 16rpx;
}
.level-left { display: flex; gap: 8rpx; align-items: baseline; }
.lv-num { font-size: 28rpx; font-weight: 700; color: #FF8DA8; }
.lv-name { font-size: 22rpx; color: #666; }
.level-mid { flex: 1; }
.lv-bar { height: 8rpx; background: #FFE0EA; border-radius: 4rpx; overflow: hidden; margin-bottom: 6rpx; }
.lv-fill { height: 100%; background: #FF8DA8; border-radius: 4rpx; }
.lv-heart { font-size: 20rpx; color: #999; }
.lv-arrow { font-size: 28rpx; color: #FF8DA8; }

.stats-row {
  display: flex;
  background: #fff;
  padding: 24rpx 0;
  margin-bottom: 16rpx;
}
.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  border-right: 1rpx solid #F0F0F0;
}
.stat-item:last-child { border-right: none; }
.stat-num { font-size: 36rpx; font-weight: 700; color: #333; }
.stat-label { font-size: 22rpx; color: #999; }

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx 16rpx;
  background: #fff;
  border-bottom: 1rpx solid #F5F5F5;
}
.section-title { font-size: 28rpx; font-weight: 700; color: #333; }
.note-add-btn {
  background: linear-gradient(135deg, #FF8DA8, #FFB3C6);
  border-radius: 32rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

.content-area { padding: 16rpx; }

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  gap: 12rpx;
}
.empty-emoji { font-size: 64rpx; }
.empty-text { font-size: 28rpx; color: #555; font-weight: 600; }
.empty-sub { font-size: 24rpx; color: #999; text-align: center; }

.private-list { display: flex; flex-direction: column; gap: 16rpx; }
.private-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.private-lock { font-size: 32rpx; flex-shrink: 0; margin-top: 4rpx; }
.private-body { flex: 1; }
.private-title { display: block; font-size: 28rpx; font-weight: 700; color: #333; margin-bottom: 8rpx; }
.private-content {
  display: block;
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}
.private-imgs { display: flex; gap: 8rpx; margin-top: 12rpx; flex-wrap: wrap; }
.private-img { width: 120rpx; height: 120rpx; border-radius: 12rpx; object-fit: cover; }
.private-date { display: block; font-size: 20rpx; color: #bbb; margin-top: 10rpx; }
.private-del { font-size: 32rpx; color: #ccc; flex-shrink: 0; padding: 4rpx; }

/* 发布弹层 */
.pub-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); z-index: 200;
}
.pub-sheet {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 24rpx 64rpx;
  z-index: 201;
  max-height: 85vh;
  overflow-y: auto;
}
.pub-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.pub-title { font-size: 30rpx; font-weight: 700; color: #333; }
.pub-close { font-size: 40rpx; color: #999; }
.pub-input {
  width: 100%;
  height: 72rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}
.pub-area {
  width: 100%;
  min-height: 200rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}
.pub-imgs { display: flex; gap: 12rpx; flex-wrap: wrap; margin-bottom: 24rpx; }
.pub-img-item { position: relative; width: 140rpx; height: 140rpx; }
.pub-img-item image { width: 100%; height: 100%; border-radius: 12rpx; object-fit: cover; }
.pub-img-del {
  position: absolute; top: -10rpx; right: -10rpx;
  width: 36rpx; height: 36rpx;
  background: rgba(0,0,0,0.5);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 24rpx;
}
.pub-img-add {
  width: 140rpx; height: 140rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 48rpx; color: #ccc;
}
.pub-submit {
  background: linear-gradient(135deg, #FF8DA8, #FFB3C6);
  border-radius: 50rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #fff;
  font-weight: 700;
}

/* 头像装饰 */
.avatar-deco {
  position: absolute;
  bottom: -6rpx;
  right: -6rpx;
  font-size: 32rpx;
  z-index: 5;
  filter: drop-shadow(0 2rpx 4rpx rgba(0,0,0,0.2));
}
.avatar-big-btn {
  position: relative !important;
}
