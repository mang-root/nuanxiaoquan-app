<!-- pages/mine/mine.wxml -->
<view class="mine-page">

<!-- 顶部(粉色渐变+设置/消息在右上角) -->
<view class="top-section">
  <view class="top-actions">
    <view class="top-btn" bindtap="gotoMessage">
      <text class="top-icon">🔔</text>
    </view>
    <view class="top-btn" bindtap="gotoSetting">
      <text class="top-icon">⚙</text>
    </view>
  </view>

  <!-- 头像+昵称区域 -->
  <view class="user-row">
    <!-- 头像:点击进个人主页 -->
    <button class="avatar-big-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" bindtap="gotoProfile">
      <view class="avatar-big" style="background: {{userInfo.avatarColor || '#FFD4DF'}};">
        <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" class="avatar-real" mode="aspectFill" />
        <text wx:else class="avatar-letter">{{userInfo.nickname ? userInfo.nickname.substring(0,1) : '同'}}</text>
      </view>
    </button>

    <view class="user-info">
      <!-- 名字:点击进编辑资料(昵称) -->
      <text class="nickname" bindtap="gotoEditNickname">{{userInfo.nickname || '同学'}} ›</text>
      <!-- 签名:点击进编辑资料(签名) -->
      <text class="sign" bindtap="gotoEditSignature">{{userInfo.signature || '点击编辑签名'}}</text>
    </view>
  </view>

  <!-- 等级卡片(单独可点击进等级页) -->
  <view class="level-card" catchtap="gotoLevel">
    <view class="level-left">
      <text class="lv-num">Lv.{{userInfo.level}}</text>
      <text class="lv-name">{{userInfo.levelName}}</text>
    </view>
    <view class="level-mid">
      <view class="lv-bar" wx:if="{{!levelInfo.isMax}}">
        <view class="lv-fill" style="width: {{levelInfo.percent+'%'}}"></view>
      </view>
      <text class="lv-heart" wx:if="{{!levelInfo.isMax}}">暖心值 {{userInfo.heartValue}} / {{levelInfo.next.required}}</text>
      <text class="lv-heart" wx:if="{{levelInfo.isMax}}">暖心值 {{userInfo.heartValue}} · 已满级</text>
    </view>
    <text class="lv-arrow">→</text>
  </view>
</view>

<!-- 四格数据 -->
<view class="stats-row">
  <view class="stat-item">
    <text class="stat-num">{{stats.totalMinutes}}</text>
    <text class="stat-label">学习分钟</text>
  </view>
  <view class="stat-item">
    <text class="stat-num">{{stats.streakDays}}</text>
    <text class="stat-label">连续打卡</text>
  </view>
  <view class="stat-item">
    <text class="stat-num">{{stats.postCount}}</text>
    <text class="stat-label">发帖</text>
  </view>
  <view class="stat-item">
    <text class="stat-num">{{stats.collectedCount}}</text>
    <text class="stat-label">收藏</text>
  </view>
</view>

<!-- 内容 Tab:我的帖子 / 我的资源 / 我的收藏 / 私密笔记 -->
<scroll-view class="content-tabs" scroll-x="true" enhanced="{{true}}" show-scrollbar="{{false}}">
  <view class="tab {{activeTab === 'post' ? 'active' : ''}}" bindtap="switchTab" data-tab="post">
    我的帖子 <text wx:if="{{myPosts.length > 0}}">({{myPosts.length}})</text>
  </view>
  <view class="tab {{activeTab === 'resource' ? 'active' : ''}}" bindtap="switchTab" data-tab="resource">
    我的资源 <text wx:if="{{myResources.length > 0}}">({{myResources.length}})</text>
  </view>
  <view class="tab {{activeTab === 'collect' ? 'active' : ''}}" bindtap="switchTab" data-tab="collect">
    我的收藏 <text wx:if="{{myCollects.length > 0}}">({{myCollects.length}})</text>
  </view>
  <view class="tab {{activeTab === 'private' ? 'active' : ''}}" bindtap="switchTab" data-tab="private">
    私密笔记 <text wx:if="{{myPrivate.length > 0}}">({{myPrivate.length}})</text>
  </view>
</scroll-view>

<!-- 内容区 -->
<view class="content-area">

  <!-- 我的帖子 -->
  <block wx:if="{{activeTab === 'post'}}">
    <view wx:if="{{myPosts.length === 0}}" class="empty-state">
      <text class="empty-emoji">✏️</text>
      <text class="empty-text">还没有发过帖子</text>
      <text class="empty-sub">去首页分享你的动态吧</text>
    </view>
    <view wx:else class="post-grid">
      <view
        wx:for="{{myPosts}}"
        wx:key="id"
        class="post-card"
        bindtap="gotoPostDetail"
        data-id="{{item.id}}"
      >
        <view wx:if="{{item.images && item.images.length > 0}}" class="pg-cover">
          <image src="{{item.images[0]}}" mode="widthFix" />
        </view>
        <view wx:else class="pg-cover-placeholder cover-{{item.id % 5}}">
          <text class="cover-emoji">📖</text>
        </view>
        <view class="pg-content">
          <text class="pg-title">{{item.title || item.content}}</text>
          <view class="pg-footer">
            <text class="pg-tag">{{item.categoryName}}</text>
            <text class="pg-like">♡ {{item.likeCount}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- 我的资源 -->
  <block wx:if="{{activeTab === 'resource'}}">
    <view wx:if="{{myResources.length === 0}}" class="empty-state">
      <text class="empty-emoji">📚</text>
      <text class="empty-text">还没有分享过资源</text>
      <text class="empty-sub">去小馆分享你的学习笔记/资料吧</text>
    </view>
    <view wx:else class="post-grid">
      <view
        wx:for="{{myResources}}"
        wx:key="id"
        class="post-card"
        bindtap="gotoResourceDetail"
        data-id="{{item.id}}"
      >
        <view wx:if="{{item.images && item.images.length > 0}}" class="pg-cover">
          <image src="{{item.images[0]}}" mode="widthFix" />
        </view>
        <view wx:else class="pg-cover-placeholder cover-{{item.id % 5}}">
          <text class="cover-emoji">📝</text>
        </view>
        <view class="pg-content">
          <text class="pg-title">{{item.title}}</text>
          <view class="pg-footer">
            <text class="pg-tag">{{item.category}}</text>
            <text class="pg-like">★ {{item.collectCount || 0}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- 我的收藏 -->
  <block wx:if="{{activeTab === 'collect'}}">
    <view wx:if="{{myCollects.length === 0}}" class="empty-state">
      <text class="empty-emoji">☆</text>
      <text class="empty-text">还没有收藏</text>
      <text class="empty-sub">去首页点 ☆ 收藏感兴趣的帖子</text>
    </view>
    <view wx:else class="post-grid">
      <view
        wx:for="{{myCollects}}"
        wx:key="id"
        class="post-card"
        bindtap="gotoPostDetail"
        data-id="{{item.id}}"
      >
        <view wx:if="{{item.images && item.images.length > 0}}" class="pg-cover">
          <image src="{{item.images[0]}}" mode="widthFix" />
        </view>
        <view wx:else class="pg-cover-placeholder cover-{{item.id % 5}}">
          <text class="cover-emoji">📖</text>
        </view>
        <view class="pg-content">
          <text class="pg-title">{{item.title || item.content}}</text>
          <view class="pg-footer">
            <text class="pg-tag">{{item.categoryName}}</text>
            <text class="pg-like">♡ {{item.likeCount}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- 私密笔记 -->
  <block wx:if="{{activeTab === 'private'}}">
    <view wx:if="{{myPrivate.length === 0}}" class="empty-state">
      <text class="empty-emoji">🔒</text>
      <text class="empty-text">还没有私密笔记</text>
      <text class="empty-sub">发帖时打开「仅自己可见」,只有你能看到</text>
    </view>
    <view wx:else class="private-list">
      <view
        wx:for="{{myPrivate}}"
        wx:key="id"
        class="private-card"
        bindtap="gotoPostDetail"
        data-id="{{item.id}}"
      >
        <view class="private-lock">🔒</view>
        <view class="private-body">
          <text wx:if="{{item.title}}" class="private-title">{{item.title}}</text>
          <text class="private-content">{{item.content}}</text>
          <view wx:if="{{item.images && item.images.length > 0}}" class="private-imgs">
            <image wx:for="{{item.images}}" wx:for-item="img" wx:key="*this" src="{{img}}" mode="aspectFill" class="private-img" />
          </view>
          <text class="private-tag">仅自己可见</text>
        </view>
      </view>
    </view>
  </block>

</view>

<view style="height: 60rpx;"></view>
</view>