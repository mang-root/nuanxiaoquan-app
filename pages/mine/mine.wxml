<!-- pages/mine/mine.wxml -->
<view class="mine-page">

<!-- 顶部(粉色渐变+设置在右上角) -->
<view class="top-section">
  <view class="top-actions">
    <view class="top-btn" bindtap="gotoSetting">
      <text class="top-icon">⚙</text>
    </view>
  </view>

  <!-- 头像+昵称区域 -->
  <view class="user-row">
    <view class="avatar-fix-wrapper">
      <button class="avatar-big-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <view class="avatar-big" style="background: {{userInfo.avatarColor || '#FFD4DF'}};">
          <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" class="avatar-real" mode="aspectFill" />
          <text wx:else class="avatar-letter">{{userInfo.nickname ? userInfo.nickname.substring(0,1) : '同'}}</text>
        </view>
        <text wx:if="{{currentDeco}}" class="avatar-deco">{{currentDeco}}</text>
      </button>
    </view>

    <view class="user-info">
      <text class="nickname" bindtap="gotoEditNickname">{{userInfo.nickname || '同学'}} ›</text>
      <text class="sign" bindtap="gotoEditSignature">{{userInfo.signature || '点击编辑签名'}}</text>
    </view>
  </view>

  <!-- 等级卡片 -->
  <view class="level-card" catchtap="gotoLevel">
    <view class="level-left">
      <text class="lv-num">Lv.{{userInfo.level}}</text>
      <text class="lv-name">{{userInfo.levelName}}</text>
    </view>
    <view class="level-mid">
      <view class="lv-bar" wx:if="{{!levelInfo.isMax}}">
        <view class="lv-fill" style="width: {{levelInfo.percent+'%'}}"></view>
      </view>
      <text class="lv-heart" wx:if="{{!levelInfo.isMax}}">暖心值 {{userInfo.heartValue}} / {{levelInfo.next.required}}</text>
      <text class="lv-heart" wx:if="{{levelInfo.isMax}}">暖心值 {{userInfo.heartValue}} · 已满级</text>
    </view>
    <text class="lv-arrow">→</text>
  </view>
</view>

<!-- 数据统计 -->
<view class="stats-row">
  <view class="stat-item">
    <text class="stat-num">{{stats.totalMinutes}}</text>
    <text class="stat-label">学习分钟</text>
  </view>
  <view class="stat-item" bindtap="gotoCheckinHistory">
    <text class="stat-num">{{stats.streakDays}}</text>
    <text class="stat-label">连续打卡 ›</text>
  </view>
  <view class="stat-item">
    <text class="stat-num">{{stats.noteCount}}</text>
    <text class="stat-label">私密笔记</text>
  </view>
</view>

<!-- 私密笔记区 -->
<view class="section-header">
  <text class="section-title">🔒 私密笔记</text>
  <view class="note-add-btn" bindtap="openAddNote">
    <text>＋ 新建笔记</text>
  </view>
</view>

<!-- 笔记列表 -->
<view class="content-area">
  <view wx:if="{{myPrivate.length === 0}}" class="empty-state">
    <text class="empty-emoji">🔒</text>
    <text class="empty-text">还没有私密笔记</text>
    <text class="empty-sub">点右上角「新建笔记」记录只属于你的内容</text>
  </view>
  <view wx:else class="private-list">
    <view
      wx:for="{{myPrivate}}"
      wx:key="id"
      class="private-card"
      bindtap="gotoNoteDetail"
      data-id="{{item.id}}"
    >
      <view class="private-lock">🔒</view>
      <view class="private-body">
        <text wx:if="{{item.title}}" class="private-title">{{item.title}}</text>
        <text class="private-content">{{item.content}}</text>
        <view wx:if="{{item.images && item.images.length > 0}}" class="private-imgs">
          <image wx:for="{{item.images}}" wx:for-item="img" wx:key="*this" src="{{img}}" mode="aspectFill" class="private-img" />
        </view>
        <text class="private-date">{{item.dateStr}}</text>
      </view>
      <view class="private-del" catchtap="deleteNote" data-id="{{item.id}}">🗑</view>
    </view>
  </view>
</view>

<!-- 新建笔记弹层 -->
<view wx:if="{{addNoteShow}}" class="pub-mask" catchtap=""></view>
<view wx:if="{{addNoteShow}}" class="pub-sheet" catchtap="">
  <view class="pub-head">
    <text class="pub-title">新建私密笔记</text>
    <text class="pub-close" bindtap="closeAddNote">×</text>
  </view>

  <input class="pub-input" placeholder="标题（可不填）" bindinput="onNoteTitle" value="{{noteForm.title}}" maxlength="30" />
  <textarea class="pub-area" placeholder="写点什么，只有你能看见..." bindinput="onNoteContent" value="{{noteForm.content}}" maxlength="5000"></textarea>

  <view class="pub-imgs">
    <view wx:for="{{noteForm.images}}" wx:key="*this" class="pub-img-item">
      <image src="{{item}}" mode="aspectFill" />
      <view class="pub-img-del" catchtap="removeNoteImage" data-idx="{{home}}">×</view>
    </view>
    <view wx:if="{{noteForm.images.length < 9}}" class="pub-img-add" bindtap="chooseNoteImages">＋</view>
  </view>

  <view class="pub-submit" bindtap="submitNote">保存笔记</view>
</view>

<view style="height: 80rpx;"></view>

<!-- AI 悬浮按钮（公共组件） -->
<ai-fab></ai-fab>
</view>
