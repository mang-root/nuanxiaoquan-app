.collect-page {
  background: #fff;
  min-height: 100vh;
}

.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
}
.tab-item.active {
  color: #333;
  font-weight: 600;
  border-bottom: 3rpx solid #F8BBD0;
}

.list-area {
  padding: 20rpx;
}
.empty {
  text-align: center;
  color: #999;
  padding: 100rpx 0;
}

/* 收藏夹列表 */
.folder-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.folder-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}
.folder-info {
  flex: 1;
}
.folder-name {
  font-size: 28rpx;
  color: #333;
  display: block;
}
.folder-count {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.add-folder-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  margin-top: 20rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  color: #666;
  font-size: 28rpx;
}
.add-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}