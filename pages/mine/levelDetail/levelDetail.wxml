<!-- pages/mine/levelDetail/levelDetail.wxml -->
<view class="level-page">

  <!-- 顶部粉色区 -->
  <view class="hero">
    <text class="hero-label">当前等级</text>
    <text class="hero-lv">{{userInfo.levelName}}</text>
    <text class="hero-num">Lv.{{userInfo.level}}</text>

    <view class="hero-bar-wrap" wx:if="{{!levelInfo.isMax}}">
      <view class="hero-bar">
        <view class="hero-fill" style="width: {{levelInfo.percent+'%'}}"></view>
      </view>
      <text class="hero-progress">{{userInfo.heartValue}} / {{levelInfo.next.required}} 暖心值</text>
      <text class="hero-next">距「{{levelInfo.next.name}}」还差 {{levelInfo.remaining}}</text>
    </view>
    <view class="hero-bar-wrap" wx:if="{{levelInfo.isMax}}">
      <text class="hero-progress">{{userInfo.heartValue}} 暖心值 · 已达满级 🎉</text>
    </view>
  </view>

  <!-- Tab -->
  <view class="tabs">
    <view class="tab {{activeTab === 'reward' ? 'active' : ''}}" bindtap="switchTab" data-tab="reward">等级奖励</view>
    <view class="tab {{activeTab === 'rule' ? 'active' : ''}}" bindtap="switchTab" data-tab="rule">暖心值规则</view>
    <view class="tab {{activeTab === 'log' ? 'active' : ''}}" bindtap="switchTab" data-tab="log">获得记录</view>
  </view>

  <!-- 内容 -->
  <view class="content">

    <!-- 等级奖励 -->
    <block wx:if="{{activeTab === 'reward'}}">
      <view
        wx:for="{{allLevels}}"
        wx:key="level"
        class="level-item {{item.isCurrent ? 'current' : ''}} {{item.isUnlocked ? 'unlocked' : 'locked'}}"
      >
        <view class="lv-head">
          <view class="lv-badge" style="background: {{item.color}};">
            <text class="lv-badge-num">{{item.level}}</text>
          </view>
          <view class="lv-title">
            <text class="lv-n">{{item.name}}</text>
            <text class="lv-req">{{item.required}} 暖心值</text>
          </view>
          <view wx:if="{{item.isCurrent}}" class="lv-tag current-tag">当前</view>
          <view wx:elif="{{item.isUnlocked}}" class="lv-tag unlocked-tag">已达成</view>
          <view wx:else class="lv-tag locked-tag">未达成</view>
        </view>
        <view class="lv-rewards">
          <view wx:for="{{item.rewards}}" wx:for-item="r" wx:key="text" class="reward-row {{r.type}}">
            <text class="reward-icon">{{r.type === 'avatarDeco' ? r.value : r.type === 'theme' ? '🎨' : r.type === 'title' ? '🏅' : '✨'}}</text>
            <text class="reward-text">{{r.text}}</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 暖心值规则 -->
    <block wx:if="{{activeTab === 'rule'}}">
      <view class="rule-tip">完成这些行为可以获得暖心值</view>
      <view wx:for="{{rules}}" wx:key="key" class="rule-row">
        <text class="rule-desc">{{item.desc}}</text>
        <view class="rule-right">
          <text class="rule-value">+{{item.value}}</text>
          <text class="rule-limit">每日上限 {{item.limit}}</text>
        </view>
      </view>
    </block>

    <!-- 获得记录 -->
    <block wx:if="{{activeTab === 'log'}}">
      <view wx:if="{{heartLogs.length === 0}}" class="empty-state">
        <text class="empty-emoji">📝</text>
        <text class="empty-text">还没有记录</text>
      </view>
      <view wx:for="{{heartLogs}}" wx:key="time" class="log-row">
        <view class="log-left">
          <text class="log-reason">{{item.reason}}</text>
          <text class="log-time">{{item.timeLabel}}</text>
        </view>
        <text class="log-value">+{{item.value}}</text>
      </view>
    </block>

  </view>

  <view style="height: 60rpx;"></view>
</view>
