<!-- pages/studyroom/studyroom.wxml -->
<view class="studyroom-page">

<!-- 状态卡片 -->
<view class="status-card">
  <view class="avatar-big" style="background: {{userInfo.avatarColor || '#FFD4DF'}};">
    <text class="avatar-big-letter">{{userInfo.nickname ? userInfo.nickname.substring(0,1) : '同'}}</text>
  </view>
  <view class="status-info">
    <text class="nickname">{{userInfo.nickname}}</text>
    <view class="level-row">
      <text class="level-name">{{userInfo.levelName}}</text>
      <text class="level-num">Lv.{{userInfo.level}}</text>
    </view>
    <view class="heart-bar" wx:if="{{!levelInfo.isMax}}">
      <view class="heart-fill" style="width: {{levelInfo.percent+'%'}}"></view>
    </view>
    <text class="heart-text" wx:if="{{!levelInfo.isMax}}">
      暖心值 {{userInfo.heartValue}} · 距「{{levelInfo.next.name}}」还差 {{levelInfo.remaining}}
    </text>
    <text class="heart-text" wx:if="{{levelInfo.isMax}}">🎉 你已满级</text>
  </view>
</view>

<!-- 快速入口（3个按钮） -->
<view class="quick-entries">
  <view class="qe-btn qe-solo" bindtap="openTomato">
    <text class="qe-icon">⏱</text>
    <text class="qe-text">暖圈钟</text>
    <text class="qe-desc">专注学习</text>
  </view>
  <view class="qe-btn qe-match" bindtap="gotoMatch">
    <text class="qe-icon">🤝</text>
    <text class="qe-text">找搭子</text>
    <text class="qe-desc">快速匹配</text>
  </view>
  <view class="qe-btn qe-create" bindtap="openCreateModal">
    <text class="qe-icon">🏠</text>
    <text class="qe-text">创建房间</text>
    <text class="qe-desc">和同学一起学</text>
  </view>
</view>

<!-- 房间列表 -->
<view class="room-section">
  <view class="room-tabs">
    <view class="room-tab {{roomTab === 'hot' ? 'active' : ''}}" bindtap="switchRoomTab" data-tab="hot">热门</view>
    <view class="room-tab {{roomTab === 'recent' ? 'active' : ''}}" bindtap="switchRoomTab" data-tab="recent">最近进入</view>
    <view class="room-tab {{roomTab === 'mine' ? 'active' : ''}}" bindtap="switchRoomTab" data-tab="mine">我创建的</view>
  </view>

  <view wx:if="{{roomList.length === 0}}" class="empty-state">
    <text class="empty-text">还没有房间</text>
    <text class="empty-sub">点上面按钮创建一个吧</text>
  </view>

  <view class="room-list">
    <view
      wx:for="{{roomList}}"
      wx:key="id"
      class="room-card"
      bindtap="enterRoom"
      data-roomid="{{item.id}}"
    >
      <view class="room-header">
        <text class="room-name">{{item.name}}{{item.password ? ' 🔒' : ''}}</text>
        <text class="room-num">{{item.currentNum}}/{{item.maxNum}}</text>
      </view>
      <view class="room-footer">
        <text class="room-topic">{{item.topic}}</text>
        <view class="room-owner-box">
          <view class="mini-avatar" style="background: {{item.ownerAvatarColor || '#FFD4DF'}};">
            <text class="mini-letter">{{item.ownerNickname ? item.ownerNickname.substring(0,1) : '同'}}</text>
          </view>
          <text class="room-owner">{{item.ownerNickname}}</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 附近自习地点 -->
<view class="nearby-entry" bindtap="openNearby">
  <text class="nearby-icon">📍</text>
  <view class="nearby-text-wrap">
    <text class="nearby-text">查看附近的图书馆、自习室</text>
    <text class="nearby-sub">基于你当前位置搜索</text>
  </view>
  <text class="nearby-arrow">→</text>
</view>

<!-- 地图合规说明 -->
<view class="map-compliance" bindtap="openMapInfo">
  <text class="compliance-text">地图服务:国家地理信息公共服务平台(天地图) · 标准地图服务</text>
  <text class="compliance-sub">tianditu.gov.cn · bzdt.ch.mnr.gov.cn</text>
</view>

<!-- 创建房间弹窗 -->
<view wx:if="{{createModalShow}}" class="mask" bindtap="closeCreateModal"></view>
<view wx:if="{{createModalShow}}" class="form-sheet" catchtap="">
  <view class="sheet-title">创建学习房间</view>
  <view class="form-row">
    <text class="form-label">房间名</text>
    <input class="input-base" placeholder="如:一起考研冲刺" bindinput="onRoomName" value="{{newRoom.name}}" maxlength="20" />
  </view>
  <view class="form-row">
    <text class="form-label">学习主题</text>
    <picker range="{{topics}}" bindchange="onRoomTopic">
      <view class="input-base">{{newRoom.topic}}</view>
    </picker>
  </view>
  <view class="form-row">
    <text class="form-label">人数上限</text>
    <input class="input-base" type="number" value="{{newRoom.maxNum}}" bindinput="onRoomMaxNum" placeholder="1-20" />
  </view>
  <view class="form-row">
    <text class="form-label">房间密码</text>
    <input class="input-base" password="{{false}}" placeholder="不填=公开房间" bindinput="onRoomPassword" value="{{newRoom.password}}" maxlength="8" />
  </view>
  <view class="form-tip">人数上限 1-20,密码可选,设置后进房需要输入</view>
  <view class="form-actions">
    <view class="btn-secondary" bindtap="closeCreateModal">取消</view>
    <view class="btn-primary" bindtap="createRoom">创建</view>
  </view>
</view>

<!-- 暖圈钟全屏 -->
<view wx:if="{{tomatoShow}}" class="tomato-fullscreen">
  <view class="tomato-header">
    <view class="tomato-close" bindtap="closeTomato">←</view>
    <text class="tomato-title">暖圈钟</text>
    <view style="width: 48rpx;"></view>
  </view>

  <view class="tomato-body">
    <view class="tomato-mode">
      <view
        wx:for="{{tomatoModes}}"
        wx:key="*this"
        class="mode-tab {{tomatoModeIndex === index ? 'active' : ''}}"
        bindtap="switchTomatoMode"
        data-idx="{{index}}"
      >{{item}}</view>
    </view>

    <view class="tomato-time-display">{{tomatoTime}}</view>

    <view wx:if="{{tomatoModeIndex === 0 && !tomatoRunning}}" class="duration-wrap">
      <text class="duration-label">选择时长</text>
      <view class="duration-btns">
        <view
          wx:for="{{[15, 25, 45, 60, 90]}}"
          wx:key="*this"
          class="dur-btn {{countdownMinutes === item ? 'active' : ''}}"
          bindtap="setCountdownMin"
          data-min="{{item}}"
        >{{item}}分</view>
        <view class="dur-btn dur-custom" bindtap="openCustomTime">自定义</view>
      </view>
      <text wx:if="{{[15,25,45,60,90].indexOf(countdownMinutes) === -1}}" class="custom-tip">当前:{{countdownMinutes}} 分钟</text>
    </view>

    <view class="tomato-action">
      <view wx:if="{{!tomatoRunning}}" class="btn-big btn-primary" bindtap="startTomato">开始专注</view>
      <view wx:if="{{tomatoRunning}}" class="btn-big btn-secondary" bindtap="stopTomato">停止</view>
    </view>

    <view class="tomato-tip">
      <text>专注 30 分钟以上 +5 暖心值</text>
    </view>
  </view>

  <!-- 自定义时长输入弹层 -->
  <view wx:if="{{customTimeShow}}" class="custom-mask" bindtap="closeCustomTime"></view>
  <view wx:if="{{customTimeShow}}" class="custom-sheet" catchtap="">
      <text class="custom-title">自定义暖圈钟时长</text>
      <input
        class="custom-input"
        type="number"
        placeholder="输入 1-180 分钟"
        value="{{customMinInput}}"
        bindinput="onCustomMinInput"
        focus="{{customTimeShow}}"
      />
      <view class="custom-actions">
        <view class="btn-secondary" bindtap="closeCustomTime">取消</view>
        <view class="btn-primary" bindtap="confirmCustomTime">确定</view>
      </view>
    </view>
</view>

</view>