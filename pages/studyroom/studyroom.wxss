/* pages/studyroom/studyroom.wxss */

.studyroom-page {
  background: #FFFFFF;
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 48rpx;
}

/* 状态卡片 */
.status-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #F8FBFF 0%, #FFFFFF 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(107, 155, 216, 0.08);
}
.avatar-big {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #FF8DA8;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.avatar-big-letter {
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: 600;
}
.status-info {
  flex: 1;
}
.nickname {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}
.level-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 6rpx 0;
}
.level-name {
  font-size: 24rpx;
  color: #FF8DA8;
  background: #FFE8F0;
  padding: 2rpx 16rpx;
  border-radius: 100rpx;
}
.level-num {
  font-size: 22rpx;
  color: #999999;
}
.heart-bar {
  height: 10rpx;
  background: #F0F0F0;
  border-radius: 5rpx;
  overflow: hidden;
  margin: 8rpx 0;
}
.heart-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF8DA8 0%, #FFC1CE 100%);
}
.heart-text {
  font-size: 20rpx;
  color: #999999;
}

/* 快速入口 */
.quick-entries {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}
.qe-btn {
  flex: 1;
  border-radius: 20rpx;
  padding: 32rpx 20rpx;
  text-align: center;
}
.qe-solo {
  background: linear-gradient(135deg, #FFF5E6 0%, #FFE8D0 100%);
}
.qe-match {
  background: linear-gradient(135deg, #fff0f0 0%, #ffe0e8 100%);
}
.qe-create {
  background: linear-gradient(135deg, #E8F1FF 0%, #D0E4FF 100%);
}
.qe-icon { display: block; font-size: 56rpx; margin-bottom: 8rpx; }
.qe-text { display: block; font-size: 28rpx; font-weight: 600; color: #333333; margin-bottom: 4rpx; }
.qe-desc { display: block; font-size: 22rpx; color: #999999; }

/* 房间区 */
.room-section {
  margin-bottom: 24rpx;
}
.room-tabs {
  display: flex;
  border-bottom: 2rpx solid #F0F0F0;
  margin-bottom: 16rpx;
}
.room-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #999999;
  position: relative;
}
.room-tab.active {
  color: #333333;
  font-weight: 600;
}
.room-tab.active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 25%;
  width: 50%;
  height: 4rpx;
  background: #FF8DA8;
  border-radius: 2rpx;
}
.room-list { }
.room-card {
  background: #FFFFFF;
  border: 1rpx solid #F0F0F0;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
}
.room-card:active {
  background: #FAFAFA;
  transform: scale(0.99);
}
.room-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.room-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}
.room-num {
  font-size: 22rpx;
  color: #FF8DA8;
  background: #FFE8F0;
  padding: 4rpx 12rpx;
  border-radius: 100rpx;
}
.room-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.room-topic {
  font-size: 22rpx;
  color: #6B9BD8;
  background: #E8F1FF;
  padding: 4rpx 12rpx;
  border-radius: 100rpx;
}
.room-owner-box {
  display: flex;
  align-items: center;
}
.mini-avatar {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 8rpx;
}
.mini-letter {
  color: #FFFFFF;
  font-size: 18rpx;
  font-weight: 600;
}
.room-owner {
  font-size: 22rpx;
  color: #999999;
}

/* 附近 */
.nearby-entry {
  display: flex;
  align-items: center;
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.nearby-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}
.nearby-text-wrap {
  flex: 1;
}
.nearby-text {
  display: block;
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 4rpx;
}
.nearby-sub {
  display: block;
  font-size: 20rpx;
  color: #999999;
}
.nearby-arrow {
  color: #CCCCCC;
  font-size: 28rpx;
}

/* 地图合规说明 */
.map-compliance {
  text-align: center;
  padding: 24rpx 16rpx;
}
.compliance-text {
  display: block;
  font-size: 20rpx;
  color: #999999;
  line-height: 1.6;
}
.compliance-sub {
  display: block;
  font-size: 18rpx;
  color: #BBBBBB;
  margin-top: 6rpx;
}

/* 空状态 */
.empty-state {
  padding: 80rpx 0;
  text-align: center;
}
.empty-text {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 8rpx;
}
.empty-sub {
  display: block;
  font-size: 22rpx;
  color: #999999;
}

/* 遮罩弹窗 */
.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-: 1000;
}
.form-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1001;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  width: 100%;
  padding: 32rpx;
  box-sizing: border-box;
}
.sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
  margin-bottom: 24rpx;
}
.form-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.form-label {
  width: 160rpx;
  font-size: 26rpx;
  color: #666666;
  flex-shrink: 0;
}
.input-base {
  flex: 1;
  background: #F7F7F7;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
}
.form-tip {
  font-size: 22rpx;
  color: #999999;
  padding: 8rpx 0;
}
.form-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}
.form-actions .btn-primary,
.form-actions .btn-secondary {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}
.btn-primary {
  background: #FF8DA8;
  color: #FFFFFF;
}
.btn-secondary {
  background: #F5F5F5;
  color: #666666;
}

/* 暖圈钟全屏 */
.tomato-fullscreen {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(180deg, #FFF5F7 0%, #FFFFFF 100%);
  z-index: 2000;
  display: flex;
  flex-direction: column;
}
.tomato-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 80rpx 32rpx 24rpx;
}
.tomato-close {
  width: 48rpx;
  font-size: 40rpx;
  color: #333333;
}
.tomato-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}
.tomato-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
}
.tomato-mode {
  display: flex;
  background: #F5F5F5;
  border-radius: 100rpx;
  padding: 6rpx;
  margin-bottom: 60rpx;
}
.mode-tab {
  padding: 12rpx 48rpx;
  font-size: 26rpx;
  color: #666666;
  border-radius: 100rpx;
}
.mode-tab.active {
  background: #FFFFFF;
  color: #FF8DA8;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.tomato-time-display {
  font-size: 160rpx;
  font-weight: 200;
  color: #FF8DA8;
  letter-spacing: 8rpx;
  margin-bottom: 48rpx;
}
.duration-wrap {
  width: 100%;
  margin-bottom: 40rpx;
}
.duration-label {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 16rpx;
}
.duration-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: center;
}
.dur-btn {
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 100rpx;
  font-size: 24rpx;
  color: #666666;
}
.dur-btn.active {
  background: #FF8DA8;
  color: #FFFFFF;
}
.dur-custom {
  background: #FFFFFF;
  color: #FF8DA8;
  border: 2rpx dashed #FF8DA8;
}
.custom-tip {
  display: block;
  text-align: center;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #FF8DA8;
}
.tomato-action {
  width: 100%;
  margin-top: 40rpx;
}
.btn-big {
  padding: 28rpx;
  text-align: center;
  border-radius: 100rpx;
  font-size: 32rpx;
  font-weight: 600;
  width: 100%;
}
.tomato-tip {
  margin-top: 32rpx;
  font-size: 22rpx;
  color: #999999;
}

/* 自定义时长遮罩 */
.custom-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 10;
}
/* 自定义时长弹层 */
.custom-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 11;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  box-sizing: border-box;
}
.custom-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24rpx;
  color: #333333;
}
.custom-input {
  background: #F7F7F7;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
  text-align: center;
  margin-bottom: 24rpx;
}
.custom-actions {
  display: flex;
  gap: 16rpx;
}
.custom-actions .btn-primary,
.custom-actions .btn-secondary {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}