<!-- pages/studyroom/roomDetail/roomDetail.wxml -->
<view class="room-page">

<!-- 顶部:房间名 + 计时 + 退出 -->
<view class="room-topbar">
  <view class="leave-btn" bindtap="leaveRoom">←</view>
  <view class="room-center">
    <text class="rt-name">{{room.name}}</text>
    <text class="rt-time">专注 {{totalTimeStr}}</text>
  </view>
  <view style="width: 80rpx;"></view>
</view>

<!-- 在线同学区 -->
<view class="members-area">
  <view class="members-grid">
    <view wx:for="{{members}}" wx:key="id" class="member-seat">
      <view class="seat-avatar" style="background: {{item.color}};">
        <text class="seat-letter">{{item.nickname ? item.nickname.substring(0,1) : '同'}}</text>
        <view wx:if="{{item.isOwner}}" class="owner-badge">房</view>
        <view wx:if="{{item.status === '学习中'}}" class="status-dot studying"></view>
      </view>
      <text class="seat-name {{item.isMe ? 'is-me' : ''}}">{{item.isMe ? '我' : item.nickname}}</text>
      <text class="seat-status">{{item.status}}</text>
    </view>
  </view>
</view>

<!-- 专注计时核心区 -->
<view class="focus-center">
  <!-- 大圆形计时按钮 -->
  <view class="focus-ring {{tomatoRunning ? 'running' : ''}}">
    <view class="focus-ring-inner">
      <text class="focus-time-big">{{tomatoTime}}</text>
      <text class="focus-label-sm">{{tomatoRunning ? '专注中' : '暖圈钟'}}</text>
    </view>
  </view>

  <!-- 时长选择(未开始时显示) -->
  <view wx:if="{{!tomatoRunning}}" class="min-picker-row">
    <text wx:for="{{[15,25,45]}}" wx:key="*this"
      class="min-btn {{tomatoMinutes === item ? 'active' : ''}}"
      bindtap="changeTomatoMin" data-min="{{item}}">{{item}}min</text>
  </view>

  <!-- 操作按钮区 -->
  <view class="focus-actions">
    <view class="side-action" bindtap="saveRoom">
      <text class="side-icon">⭐</text>
      <text class="side-text">收藏</text>
    </view>

    <view wx:if="{{!tomatoRunning}}" class="focus-main-btn" bindtap="startRoomTomato">
      <text class="focus-btn-text">开始专注</text>
    </view>
    <view wx:if="{{tomatoRunning}}" class="focus-main-btn focus-stop-btn" bindtap="stopRoomTomato">
      <text class="focus-btn-text">结束专注</text>
    </view>

    <view class="side-action" bindtap="shareResult">
      <text class="side-icon">📤</text>
      <text class="side-text">分享</text>
    </view>
  </view>
</view>

<!-- 底部数据卡片 -->
<view class="data-cards">
  <view class="data-card">
    <text class="data-icon">👥</text>
    <text class="data-num">{{members.length}}</text>
    <text class="data-desc">在线人数</text>
  </view>
  <view class="data-card">
    <text class="data-icon">📚</text>
    <text class="data-num">{{todayRoomMin}}</text>
    <text class="data-desc">今日专注(分)</text>
  </view>
  <view class="data-card">
    <text class="data-icon">⭐</text>
    <text class="data-num">{{userInfo.heartValue || 0}}</text>
    <text class="data-desc">暖心值</text>
  </view>
</view>

</view>
