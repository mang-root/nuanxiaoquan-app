/* pages/studyroom/roomDetail/roomDetail.wxss */

page {
  height: 100vh;
  background: #F7F7F7;
}

.room-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 顶部栏 */
.room-topbar {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 24rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F0F0F0;
  min-height: 88rpx;
}
.room-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 8rpx;
}
.rt-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  word-break: break-all;
  white-space: normal;
  line-height: 1.4;
}
.rt-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}
.chat-toggle-btn {
  padding: 8rpx 16rpx;
  background: #f5f5f5;
  border-radius: 100rpx;
  font-size: 22rpx;
  color: #666;
  white-space: nowrap;
  flex-shrink: 0;
}
.leave-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 40rpx;
  color: #333333;
  margin-right: 16rpx;
}

/* 成员区 */
.members-area {
  background: linear-gradient(135deg, #F8FBFF 0%, #FFFFFF 100%);
  padding: 24rpx 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}
.members-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx 8rpx;
}
.member-seat {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.seat-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-bottom: 8rpx;
}
.seat-letter {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
}
.owner-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  background: #FF8DA8;
  color: #FFFFFF;
  font-size: 18rpx;
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 50%;
  border: 2rpx solid #FFFFFF;
}
.status-dot {
  position: absolute;
  bottom: 0;
  right: 4rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  border: 2rpx solid #FFFFFF;
}
.status-dot.studying {
  background: #7DCE82;
}
.seat-name {
  font-size: 22rpx;
  color: #333333;
  max-width: 100rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.seat-name.is-me {
  color: #FF8DA8;
  font-weight: 600;
}
.seat-status {
  font-size: 18rpx;
  color: #999999;
  margin-top: 2rpx;
}

/* 共享暖圈钟 */
.tomato-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #FFF5E6 0%, #FFE8D0 100%);
  border-bottom: 1rpx solid #F0F0F0;
  gap: 12rpx;
}
.tomato-left {
  display: flex;
  align-items: center;
  flex: 1;
}
.tomato-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}
.tomato-info {
  display: flex;
  flex-direction: column;
}
.tomato-label {
  font-size: 22rpx;
  color: #666666;
}
.tomato-time {
  font-size: 30rpx;
  font-weight: 600;
  color: #FF8DA8;
}
.tomato-min-picker {
  display: flex;
  gap: 4rpx;
}
.tmp-btn {
  padding: 4rpx 10rpx;
  background: #FFFFFF;
  border-radius: 100rpx;
  font-size: 20rpx;
  color: #666666;
}
.tmp-btn.active {
  background: #FF8DA8;
  color: #FFFFFF;
}
.tomato-start-btn, .tomato-stop-btn {
  padding: 12rpx 24rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  color: #FFFFFF;
}
.tomato-start-btn {
  background: #FF8DA8;
}
.tomato-stop-btn {
  background: #999999;
}

/* 聊天区 */
.chat-area {
  flex: 1;
  padding: 16rpx 24rpx;
  background: #F7F7F7;
  height: 0;
}

.msg-wrap {
  display: flex;
  margin-bottom: 20rpx;
}
.msg-wrap.me {
  justify-content: flex-end;
}
.msg-wrap.system {
  justify-content: center;
}

.system-msg {
  padding: 8rpx 16rpx;
  background: rgba(0,0,0,0.08);
  color: #666666;
  font-size: 22rpx;
  border-radius: 100rpx;
}

/* 别人消息：头像左 + 气泡右 */
.msg-item.other {
  display: flex;
  align-items: flex-start;
  flex-direction: row;
}

/* 我的消息：头像右 + 气泡左 */
.msg-item.mine {
  display: flex;
  align-items: flex-start;
  flex-direction: row-reverse;
}

/* 头像 */
.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin: 0 12rpx;
}
.msg-letter {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
}

/* 气泡 */
.msg-box {
  max-width: 70%;
  display: flex;
  flex-direction: column;
}
.msg-item.mine .msg-box {
  align-items: flex-end;
}

.msg-bubble {
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.4;
  word-wrap: break-word;
  word-break: break-all;
}

/* 别人气泡（保留你原来的白色） */
.msg-item.other .msg-bubble {
  background: #ffffff;
  color: #333;
}

/* 我的气泡（保留你原来的粉色） */
.msg-item.mine .msg-bubble {
  background: #FF8DA8;
  color: #fff;
}

.msg-bubble.check-in {
  background: linear-gradient(135deg, #FFE8F0 0%, #FFD4DF 100%);
  color: #FF8DA8;
  font-weight: 600;
}

/* 快捷短语 */
.quick-bar {
  white-space: nowrap;
  padding: 12rpx 24rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #F0F0F0;
}
.quick-btn {
  display: inline-block;
  padding: 10rpx 20rpx;
  margin-right: 12rpx;
  background: #F5F5F5;
  border-radius: 100rpx;
  font-size: 22rpx;
  color: #666666;
}

/* 输入栏 */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx 32rpx;
  background: #FFFFFF;
  gap: 12rpx;
}
.msg-input {
  flex: 1;
  height: 72rpx;
  background: #F5F5F5;
  border-radius: 100rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
}
.send-btn {
  padding: 16rpx 32rpx;
  background: #FF8DA8;
  color: #FFFFFF;
  border-radius: 100rpx;
  font-size: 26rpx;
}

/* 聊天开关 */
.chat-toggle {
  font-size: 24rpx;
  background: #fff;
  border: 1rpx solid #FF8DA8;
  color: #FF8DA8;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 10rpx;
}

/* 房间总计时 */
.total-time {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

/* 自定义时长输入框 */
.tmp-input {
  width: 80rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background: #f5f5f5;
  border-radius: 24rpx;
  font-size: 24rpx;
  margin-left: 8rpx;
}

/* ===== 新聊天气泡样式 ===== */
.msg-item {
  display: flex;
  align-items: flex-end;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}
.msg-item.other {
  flex-direction: row;
}
.msg-item.mine {
  flex-direction: row-reverse;
}

.msg-avatar-sm {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.msg-item.other .msg-avatar-sm {
  margin-right: 12rpx;
}
.msg-item.mine .msg-avatar-sm {
  margin-left: 12rpx;
}
.msg-letter-sm {
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
}

.msg-right {
  display: flex;
  flex-direction: column;
  max-width: 70%;
}
.msg-name-sm {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 6rpx;
  padding-left: 4rpx;
}

.msg-bubble {
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  word-break: break-all;
  max-width: 100%;
}
.other-bubble {
  background: #f0f0f0;
  border-top-left-radius: 4rpx;
}
.mine-bubble {
  background: #e8f1ff;
  border-top-right-radius: 4rpx;
  max-width: 70%;
}