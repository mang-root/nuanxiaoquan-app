/* pages/studyroom/roomDetail/roomDetail.wxss */

page {
  background: linear-gradient(180deg, #FFF5F7 0%, #F0F4FF 50%, #F5FFF8 100%);
  min-height: 100vh;
}

.room-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-bottom: 48rpx;
}

/* 顶部栏 */
.room-topbar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid rgba(255,141,168,0.1);
}
.leave-btn {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: rgba(255,141,168,0.1);
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; color: #FF8DA8;
}
.room-center {
  flex: 1;
  display: flex; flex-direction: column; align-items: center;
}
.rt-name { font-size: 30rpx; font-weight: 700; color: #333; }
.rt-time { font-size: 22rpx; color: #FF8DA8; margin-top: 4rpx; }

/* 在线成员 */
.members-area {
  background: rgba(255,255,255,0.7);
  margin: 16rpx;
  border-radius: 24rpx;
  padding: 20rpx;
}
.members-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.member-seat {
  display: flex; flex-direction: column; align-items: center;
  gap: 6rpx;
  width: 100rpx;
}
.seat-avatar {
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  position: relative;
  border: 2rpx solid rgba(255,255,255,0.8);
}
.seat-letter { font-size: 28rpx; color: #fff; font-weight: 700; }
.owner-badge {
  position: absolute; top: -4rpx; right: -4rpx;
  background: #FFB946; color: #fff;
  font-size: 16rpx; border-radius: 6rpx; padding: 0 6rpx;
}
.status-dot {
  position: absolute; bottom: 2rpx; right: 2rpx;
  width: 16rpx; height: 16rpx;
  border-radius: 50%; background: #4CAF50;
  border: 2rpx solid #fff;
}
.seat-name { font-size: 22rpx; color: #333; font-weight: 600; }
.seat-name.is-me { color: #FF8DA8; }
.seat-status { font-size: 18rpx; color: #999; }

/* 专注核心区 */
.focus-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 24rpx;
  gap: 32rpx;
}

.focus-ring {
  width: 320rpx; height: 320rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFE8EE, #FFF5F7);
  border: 6rpx solid #FFD4DF;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 40rpx rgba(255,141,168,0.2), inset 0 2rpx 8rpx rgba(255,255,255,0.8);
  transition: all 0.3s;
}
.focus-ring.running {
  border-color: #FF8DA8;
  box-shadow: 0 8rpx 60rpx rgba(255,141,168,0.4), inset 0 2rpx 8rpx rgba(255,255,255,0.8);
  animation: pulse 2s infinite;
}
@keyframes pulse {
  0%, 100% { box-shadow: 0 8rpx 60rpx rgba(255,141,168,0.4); }
  50% { box-shadow: 0 8rpx 80rpx rgba(255,141,168,0.7); }
}
.focus-ring-inner { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.focus-time-big { font-size: 72rpx; font-weight: 800; color: #FF8DA8; letter-spacing: 4rpx; }
.focus-label-sm { font-size: 24rpx; color: #FFB3C6; }

.min-picker-row {
  display: flex; gap: 16rpx;
}
.min-btn {
  background: #FFF0F4;
  border-radius: 50rpx;
  padding: 12rpx 32rpx;
  font-size: 26rpx; color: #FF8DA8;
  border: 2rpx solid #FFD4DF;
}
.min-btn.active {
  background: #FF8DA8; color: #fff;
  border-color: #FF8DA8;
}

.focus-actions {
  display: flex; align-items: center; gap: 32rpx;
}
.side-action {
  display: flex; flex-direction: column; align-items: center; gap: 6rpx;
  padding: 16rpx;
}
.side-icon { font-size: 40rpx; }
.side-text { font-size: 20rpx; color: #999; }

.focus-main-btn {
  background: linear-gradient(135deg, #FF8DA8, #FF6B99);
  border-radius: 60rpx;
  padding: 24rpx 64rpx;
  box-shadow: 0 6rpx 24rpx rgba(255,141,168,0.4);
}
.focus-stop-btn {
  background: linear-gradient(135deg, #A8C7FA, #7BA8F7);
  box-shadow: 0 6rpx 24rpx rgba(120,160,240,0.3);
}
.focus-btn-text { font-size: 30rpx; font-weight: 700; color: #fff; }

/* 底部数据卡片 */
.data-cards {
  display: flex;
  margin: 0 16rpx;
  gap: 12rpx;
}
.data-card {
  flex: 1;
  background: rgba(255,255,255,0.9);
  border-radius: 20rpx;
  padding: 20rpx 12rpx;
  display: flex; flex-direction: column; align-items: center;
  gap: 6rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.data-icon { font-size: 36rpx; }
.data-num { font-size: 32rpx; font-weight: 700; color: #333; }
.data-desc { font-size: 20rpx; color: #999; }
