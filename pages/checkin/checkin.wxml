<view class="page">
  <view class="top-bar">
    <view class="back-btn" bindtap="goBack">‹</view>
    <text class="page-title">打卡记录</text>
    <view style="width:60rpx;"></view>
  </view>

  <view class="stats-row">
    <view class="stat-card">
      <text class="stat-num">{{streakDays}}</text>
      <text class="stat-label">连续打卡</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-card">
      <text class="stat-num">{{totalDays}}</text>
      <text class="stat-label">累计打卡</text>
    </view>
  </view>

  <view wx:if="{{history.length === 0}}" class="empty">
    <text class="empty-emoji">📆</text>
    <text class="empty-text">还没有打卡记录，去首页打卡吧～</text>
  </view>

  <view class="list" wx:else>
    <view class="record" wx:for="{{history}}" wx:key="date">
      <view class="record-date">
        <text class="date-main">{{item.dateLabel}}</text>
        <text class="date-week">周{{item.weekLabel}}</text>
      </view>
      <view class="record-mood" style="background: {{item.color}};">
        <text class="mood-text">{{item.mood}}</text>
      </view>
    </view>
  </view>
</view>
