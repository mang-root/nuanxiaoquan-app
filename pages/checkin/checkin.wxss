page { background: #faf9f7; }
.page { min-height: 100vh; }
.top-bar { display: flex; align-items: center; justify-content: space-between; padding: 50rpx 24rpx 20rpx; background: #fff; }
.back-btn { font-size: 40rpx; color: #555; width: 60rpx; }
.page-title { font-size: 32rpx; font-weight: 700; color: #2d2d2d; }
.stats-row { display: flex; background: #fff; margin: 16rpx 24rpx; border-radius: 20rpx; padding: 32rpx 0; align-items: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.stat-card { flex: 1; text-align: center; }
.stat-num { display: block; font-size: 44rpx; font-weight: 700; color: #FF8DA8; }
.stat-label { display: block; font-size: 24rpx; color: #aaa; margin-top: 6rpx; }
.stat-divider { width: 2rpx; height: 60rpx; background: #f0f0f0; }
.empty { text-align: center; padding: 80rpx 0; }
.empty-emoji { display: block; font-size: 60rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 26rpx; color: #bbb; }
.list { padding: 0 24rpx; }
.record { display: flex; align-items: center; justify-content: space-between; background: #fff; border-radius: 16rpx; padding: 24rpx 28rpx; margin-bottom: 12rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.record-date { display: flex; flex-direction: column; }
.date-main { font-size: 28rpx; color: #333; font-weight: 500; }
.date-week { font-size: 22rpx; color: #bbb; margin-top: 4rpx; }
.record-mood { border-radius: 24rpx; padding: 12rpx 28rpx; }
.mood-text { font-size: 26rpx; color: #555; }
