/* pages/postDetail/postDetail.wxss */

.detail-page {
  background: #FFFFFF;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* 作者栏 */
.author-bar {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}
.avatar-placeholder {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.avatar-sm {
  width: 56rpx;
  height: 56rpx;
}
.avatar-letter {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
}
.avatar-sm .avatar-letter {
  font-size: 22rpx;
}
.author-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.author-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}
.author-level {
  font-size: 22rpx;
  color: #FF8DA8;
  margin-top: 4rpx;
}
.collect-author {
  padding: 12rpx 24rpx;
  border: 1rpx solid #FF8DA8;
  color: #FF8DA8;
  border-radius: 100rpx;
  font-size: 24rpx;
}

/* 图片轮播 */
.image-swiper {
  width: 100%;
  background: #F5F5F5;
}
.swiper-img {
  width: 100%;
  height: 100%;
}

/* 正文 */
.content-area {
  padding: 24rpx;
}
.post-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  line-height: 1.4;
  margin-bottom: 16rpx;
}
.post-tags {
  margin-bottom: 16rpx;
}
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  background: #F5F5F5;
  color: #666666;
  margin-right: 8rpx;
}
.tag-learn {
  background: #E8F1FF;
  color: #6B9BD8;
}
.post-content {
  display: block;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  white-space: pre-wrap;
  margin-bottom: 24rpx;
}
.post-time {
  font-size: 22rpx;
  color: #999999;
}

.divider {
  height: 16rpx;
  background: #F5F5F5;
}

/* 评论区 */
.comments-area {
  padding: 24rpx;
}
.comments-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}
.no-comments {
  padding: 60rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #999999;
}
.comment-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.comment-body {
  flex: 1;
  margin-left: 12rpx;
}
.comment-name {
  display: block;
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 6rpx;
}
.comment-text {
  display: block;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx 32rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #F0F0F0;
  gap: 16rpx;
}
.comment-input-wrap {
  flex: 1;
  background: #F5F5F5;
  border-radius: 100rpx;
  padding: 16rpx 24rpx;
}
.comment-input-placeholder {
  color: #999999;
  font-size: 26rpx;
}
.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 4rpx 12rpx;
}
.action-icon {
  font-size: 40rpx;
  color: #666666;
  line-height: 1;
}
.action-icon.active {
  color: #FF8DA8;
}
.action-count {
  font-size: 20rpx;
  color: #999999;
  margin-top: 2rpx;
}

/* 评论弹层 */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}
.comment-sheet {
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  width: 100%;
  padding: 32rpx;
}
.comment-textarea {
  width: 100%;
  min-height: 200rpx;
  background: #F7F7F7;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
}
.comment-sheet-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}
.comment-count-tip {
  font-size: 22rpx;
  color: #999999;
}
.btn-primary {
  padding: 16rpx 40rpx;
  background: #FF8DA8;
  color: #FFFFFF;
  border-radius: 100rpx;
  font-size: 26rpx;
}

.empty-state {
  padding: 200rpx 0;
  text-align: center;
}
.empty-text {
  color: #999999;
  font-size: 26rpx;
}
