.detail-page { padding: 24rpx; background: #fff; min-height: 100vh; }
.author-bar { display: flex; align-items: center; gap: 16rpx; margin-bottom: 24rpx; }
.d-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.d-letter { font-size: 28rpx; color: #fff; font-weight: 700; }
.d-info { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.d-name { font-size: 28rpx; font-weight: 700; color: #333; }
.d-official { font-size: 20rpx; color: #FF8DA8; }
.d-time { font-size: 20rpx; color: #999; }
.d-cate-tag { background: #FFF0F4; color: #FF8DA8; font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 20rpx; }
.d-title { display: block; font-size: 34rpx; font-weight: 700; color: #222; margin-bottom: 20rpx; line-height: 1.5; }
.d-content { display: block; font-size: 28rpx; color: #444; line-height: 1.8; white-space: pre-wrap; }
.d-imgs { margin-top: 20rpx; display: flex; flex-direction: column; gap: 12rpx; }
.d-img { width: 100%; border-radius: 16rpx; }
