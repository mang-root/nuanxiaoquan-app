.container {
  background: #ffffff;
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 160rpx;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 10rpx 0;
}
.tab-switch {
  display: flex;
  gap: 20rpx;
}
.tab {
  font-size: 30rpx;
  color: #666;
  padding: 10rpx 20rpx;
}
.tab.on {
  color: #ff8da8;
  font-weight: bold;
  border-bottom: 3rpx solid #ff8da8;
}
.filter-btn {
  font-size: 26rpx;
  color: #333;
  padding: 10rpx 24rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
}

.cate-scroll {
  white-space: nowrap;
  margin-bottom: 30rpx;
  width: 100%;
}
.cate {
  display: inline-block;
  padding: 14rpx 26rpx;
  background: #f9f9f9;
  border-radius: 50rpx;
  font-size: 26rpx;
  margin-right: 16rpx;
  color: #333;
}
.cate.on {
  background: #ff8da8;
  color: #fff;
}

.list {
  padding-bottom: 40rpx;
}
.card {
  background: #f9f9f9;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.user-bar {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #ffd6e0;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.avatar-letter {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}
.info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}
.level {
  font-size: 22rpx;
  color: #ff8da8;
  margin-top: 4rpx;
}
.cate-tag {
  padding: 4rpx 16rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
}
.cate-tag-study {
  background: #e8f1ff;
  color: #6b9bd8;
}
.cate-tag-mood {
  background: #ffe8f0;
  color: #ff8da8;
}
.cate-tag-daily {
  background: #fff5e6;
  color: #e8a05a;
}

.post-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}
.content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 16rpx;
  /* 列表最多显示 3 行 */
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.img-row {
  display: flex;
  gap: 8rpx;
  margin-bottom: 16rpx;
}
.post-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: #eee;
}

.action {
  display: flex;
  align-items: center;
  gap: 32rpx;
  color: #666;
  font-size: 24rpx;
}
.act-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.act-icon {
  font-size: 28rpx;
  color: #999;
}
.act-icon.liked {
  color: #ff8da8;
}
.private-tag {
  margin-left: auto;
  background: #f0f0f0;
  color: #999;
  padding: 4rpx 12rpx;
  border-radius: 100rpx;
  font-size: 20rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
}
.empty-emoji {
  font-size: 72rpx;
  margin-bottom: 12rpx;
}
.empty-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 6rpx;
}
.empty-sub {
  font-size: 22rpx;
  color: #999;
}

/* 筛选弹窗 */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.3);
  z-index: 10;
}
.filter-panel {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: #fff;
  border-radius: 20rpx;
  width: 70%;
  z-index: 11;
  overflow: hidden;
}
.filter-panel .item {
  padding: 30rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  border-bottom: 1rpx solid #eee;
}
.filter-panel .item:last-child {
  border-bottom: none;
}
.filter-panel .item.on {
  color: #ff8da8;
  font-weight: 600;
}

/* 发帖按钮 */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 48rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #ff8da8;
  box-shadow: 0 6rpx 20rpx rgba(255, 141, 168, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9;
}
.fab-plus {
  color: #fff;
  font-size: 52rpx;
  line-height: 1;
  font-weight: 300;
}

/* 发帖弹层 */
.pub-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
}
.pub-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1001;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  width: 100%;
  padding: 32rpx;
  max-height: 90vh;
  overflow-y: auto;
  box-sizing: border-box;
}
.pub-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.pub-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}
.pub-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}
.pub-input {
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}
.pub-area {
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  width: 100%;
  min-height: 240rpx;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}
.pub-imgs {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.pub-img-item {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}
.pub-img-item image {
  width: 100%;
  height: 100%;
}
.pub-img-del {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 28rpx;
}
.pub-img-add {
  width: 180rpx;
  height: 180rpx;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  color: #ccc;
  font-weight: 300;
}
.pub-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
}
.pub-label {
  font-size: 26rpx;
  color: #333;
  display: block;
}
.pub-sub {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}
.pub-picker {
  font-size: 26rpx;
  color: #666;
}
.pub-submit {
  background: #ff8da8;
  color: #fff;
  padding: 24rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 24rpx;
}
/* 限制分类文字提示 */
.pub-cate-tip {
  font-size: 20rpx;
  color: #f5a623;
  padding: 4rpx 0 12rpx;
}

/* 打卡按钮 */
.checkin-btn {
  padding: 10rpx 20rpx;
  background: #fff0f4;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #ff8da8;
  margin-left: 8rpx;
}

/* 情绪打卡弹层 */
.checkin-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1001;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 24rpx 48rpx;
}
.checkin-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 8rpx;
}
.checkin-sub {
  font-size: 22rpx;
  color: #999;
  text-align: center;
  margin-bottom: 32rpx;
}
.mood-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}
.mood-btn {
  border-radius: 16rpx;
  padding: 28rpx 0;
  text-align: center;
  box-shadow: 0 4rpx 0 rgba(0,0,0,0.06);
  position: relative;
  top: 0;
  transition: top 0.1s, box-shadow 0.1s;
}
.mood-btn:active {
  top: 4rpx;
  box-shadow: none;
}
.mood-label {
  font-size: 28rpx;
  color: #555;
  font-weight: 500;
}