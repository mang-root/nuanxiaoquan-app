<view class="container">

<!-- 顶部栏 -->
<view class="top-bar">
  <view class="tab-switch">
    <text class="tab {{tabType=='new'?'on':''}}" bindtap="switchTab" data-type="new">最新</text>
    <text class="tab {{tabType=='hot'?'on':''}}" bindtap="switchTab" data-type="hot">热门</text>
  </view>
  <view class="filter-btn" bindtap="showFilter">
    <text>{{filterDay > 0 ? '近' + filterDay + '天' : '筛选'}}</text>
  </view>
  <view class="checkin-btn" bindtap="openCheckin">
    <text>{{todayMood ? todayMood : '打卡'}}</text>
  </view>
</view>

<!-- 分类标签 -->
<scroll-view class="cate-scroll" scroll-x="true" show-scrollbar="false">
  <view class="cate {{cate === -1 ? 'on' : ''}}" bindtap="switchCate" data-index="-1">全部</view>
  <view
    class="cate {{cate == index ? 'on' : ''}}"
    wx:for="{{cateList}}"
    wx:key="index"
    bindtap="switchCate"
    data-index="{{index}}"
  >{{item}}</view>
</scroll-view>

<!-- 动态列表 -->
<view class="list">
  <view wx:if="{{list.length === 0}}" class="empty">
    <text class="empty-emoji">📝</text>
    <text class="empty-text">还没有动态</text>
    <text class="empty-sub">点右下角 + 发第一条吧</text>
  </view>

  <view class="card" wx:for="{{list}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
    <view class="user-bar">
      <view
        class="avatar"
        style="background: {{item.authorAvatarColor || '#ffd6e0'}};"
        catchtap="gotoAuthorProfile"
        data-nickname="{{item.authorNickname}}"
      >
        <text class="avatar-letter">{{item.authorNickname ? item.authorNickname.substring(0,1) : '同'}}</text>
      </view>
      <view class="info">
        <text class="name">{{item.authorNickname}}</text>
        <text class="level">{{item.authorLevelName}} · LV.{{item.authorLevel}}</text>
      </view>
      <view class="cate-tag cate-tag-{{item.categoryName === '知学' ? 'study' : item.categoryName === '心安' ? 'mood' : 'daily'}}">
        {{item.categoryName}}
      </view>
    </view>

    <view wx:if="{{item.title}}" class="post-title">{{item.title}}</view>
    <view class="content">{{item.content}}</view>

    <view wx:if="{{item.images && item.images.length > 0}}" class="img-row">
      <image
        wx:for="{{item.images}}"
        wx:for-item="img"
        wx:key="*this"
        src="{{img}}"
        mode="aspectFill"
        class="post-img"
      />
    </view>

    <view class="action">
      <view class="act-btn" catchtap="likeCard" data-id="{{item.id}}">
        <text class="act-icon {{item.liked ? 'liked' : ''}}">{{item.liked ? '❤' : '♡'}}</text>
        <text>{{item.likeCount || 0}}</text>
      </view>
      <view class="act-btn">
        <text class="act-icon">💬</text>
        <text>{{item.commentCount || 0}}</text>
      </view>
      <view wx:if="{{item.privateOnly}}" class="private-tag">仅自己可见</view>
    </view>
  </view>
</view>

<!-- 筛选弹窗 -->
<view class="mask" wx:if="{{showFilter}}" bindtap="closeFilter"></view>
<view class="filter-panel" wx:if="{{showFilter}}">
  <view class="item {{filterDay === 0 ? 'on' : ''}}" bindtap="clearFilter">全部</view>
  <view class="item {{filterDay === 1 ? 'on' : ''}}" bindtap="setFilter" data-day="1">近 1 天</view>
  <view class="item {{filterDay === 3 ? 'on' : ''}}" bindtap="setFilter" data-day="3">近 3 天</view>
  <view class="item {{filterDay === 30 ? 'on' : ''}}" bindtap="setFilter" data-day="30">近 1 月</view>
  <view class="item {{filterDay === 180 ? 'on' : ''}}" bindtap="setFilter" data-day="180">近半年</view>
  <view class="item {{filterDay === 365 ? 'on' : ''}}" bindtap="setFilter" data-day="365">近 1 年</view>
</view>

<!-- 悬浮发帖按钮 -->
<view class="fab" bindtap="openPublish">
  <text class="fab-plus">＋</text>
</view>

<!-- 发帖弹层 -->
<view wx:if="{{publishShow}}" class="pub-mask" bindtap="closePublish"></view>
<view wx:if="{{publishShow}}" class="pub-sheet" catchtap="">
  <view class="pub-head">
    <text class="pub-title">发动态</text>
    <text class="pub-close" bindtap="closePublish">×</text>
  </view>

  <input class="pub-input" placeholder="标题(可不填)" bindinput="onPubTitle" value="{{publishForm.title}}" maxlength="30" />

  <textarea class="pub-area" placeholder="说点什么..." bindinput="onPubContent" value="{{publishForm.content}}" maxlength="2000"></textarea>

  <view class="pub-imgs">
    <view wx:for="{{publishForm.images}}" wx:key="*this" class="pub-img-item">
      <image src="{{item}}" mode="aspectFill" />
      <view class="pub-img-del" catchtap="removePubImage" data-idx="{{index}}">×</view>
    </view>
    <view wx:if="{{publishForm.images.length < 3}}" class="pub-img-add" bindtap="choosePubImages">＋</view>
  </view>

  <view class="pub-row">
    <text class="pub-label">分类</text>
    <picker range="{{cateList}}" bindchange="onPubCate" value="{{publishForm.cateIndex}}">
      <view class="pub-picker">{{cateList[publishForm.cateIndex]}} ▾</view>
    </picker>
  </view>
  <view class="pub-cate-tip">请确保内容与分类匹配,否则会被举报删除</view>

  <view class="pub-row">
    <view>
      <text class="pub-label">仅自己可见</text>
      <text class="pub-sub">烦躁或私密的内容开启,别人看不到</text>
    </view>
    <switch checked="{{publishForm.privateOnly}}" bindchange="onPubPrivateChange" color="#ff8da8" />
  </view>

  <view class="pub-submit" bindtap="submitPost">发布</view>
</view>

<!-- 情绪打卡弹层 -->
<view wx:if="{{checkinShow}}" class="mask" catchtap="closeCheckin"></view>
<view wx:if="{{checkinShow}}" class="checkin-sheet" catchtap="">
  <view class="checkin-title">今日打卡</view>
  <view class="checkin-sub">选一个最符合你现在状态的词</view>
  <view class="mood-grid">
    <view
      wx:for="{{moodList}}"
      wx:key="label"
      class="mood-btn"
      style="background: {{item.color}};"
      bindtap="selectMood"
      data-label="{{item.label}}"
    >
      <text class="mood-label">{{item.label}}</text>
    </view>
  </view>
</view>

</view>