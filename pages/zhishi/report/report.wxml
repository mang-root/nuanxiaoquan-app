<!-- pages/zhishi/report/report.wxml -->
<view class="report-page">

  <!-- ============== 学习报告 ============== -->
  <block wx:if="{{mode === 'plan'}}">
    <view class="report-header">
      <text class="header-title">学习报告</text>
      <text class="header-subtitle">你的学习成长记录</text>
    </view>

    <!-- 总览 -->
    <view class="stats-grid">
      <view class="stat-box">
        <text class="stat-num text-learn">{{planReport.totalMinutes}}</text>
        <text class="stat-label">累计学习分钟</text>
      </view>
      <view class="stat-box">
        <text class="stat-num text-learn">{{planReport.doneTasks}}</text>
        <text class="stat-label">完成任务数</text>
      </view>
      <view class="stat-box">
        <text class="stat-num text-learn">{{planReport.completionRate}}%</text>
        <text class="stat-label">完成率</text>
      </view>
      <view class="stat-box">
        <text class="stat-num text-learn">{{planReport.streakDays}}</text>
        <text class="stat-label">连续打卡天数</text>
      </view>
    </view>

    <!-- 最近 4 周趋势 -->
    <view class="section">
      <text class="section-title">最近 4 周学习时长</text>
      <view class="trend-chart">
        <view wx:for="{{planReport.weekTrendHeight}}" wx:key="index" class="trend-bar-wrap">
          <text class="trend-value">{{planReport.weekTrend[index]}}</text>
          <view class="trend-bar" style="height: {{item}}rpx"></view>
          <text class="trend-label">{{index === 3 ? '本周' : (3 - index) + '周前'}}</text>
        </view>
      </view>
    </view>

    <!-- 分类占比 -->
    <view class="section" wx:if="{{planReport.categoryStats.length > 0}}">
      <text class="section-title">任务分类占比</text>
      <view class="category-list">
        <view wx:for="{{planReport.categoryStats}}" wx:key="name" class="cat-row">
          <text class="cat-name">{{item.name}}</text>
          <view class="cat-progress">
            <view class="cat-fill" style="width: {{item.percent+'%'}}"></view>
          </view>
          <text class="cat-percent">{{item.percent}}%</text>
        </view>
      </view>
    </view>

    <!-- 学习时段 -->
    <view class="section">
      <text class="section-title">学习时段分布</text>
      <view class="slot-grid">
        <view class="slot-box">
          <text class="slot-emoji">🌅</text>
          <text class="slot-label">早上</text>
          <text class="slot-value">{{planReport.timeSlotStats.morning}}</text>
        </view>
        <view class="slot-box">
          <text class="slot-emoji">☀️</text>
          <text class="slot-label">中午</text>
          <text class="slot-value">{{planReport.timeSlotStats.noon}}</text>
        </view>
        <view class="slot-box">
          <text class="slot-emoji">🌇</text>
          <text class="slot-label">下午</text>
          <text class="slot-value">{{planReport.timeSlotStats.evening}}</text>
        </view>
        <view class="slot-box">
          <text class="slot-emoji">🌙</text>
          <text class="slot-label">晚上</text>
          <text class="slot-value">{{planReport.timeSlotStats.night}}</text>
        </view>
      </view>
    </view>

    <!-- 最高效的一天 -->
    <view class="highlight-card" wx:if="{{planReport.bestDayMinutes > 0}}">
      <text class="highlight-icon">🏆</text>
      <view class="highlight-info">
        <text class="highlight-title">最高效的一天</text>
        <text class="highlight-desc">{{planReport.bestDay}} · 共学习 {{planReport.bestDayMinutes}} 分钟</text>
      </view>
    </view>

    <view wx:if="{{planReport.totalTasks === 0}}" class="empty-state">
      <text class="empty-text">还没有学习记录,快去「知时」添加你的第一个学习任务吧</text>
    </view>
  </block>

  <!-- ============== 月度报告 ============== -->
  <block wx:if="{{mode === 'account'}}">
    <view class="report-header">
      <text class="header-title">{{accountReport.monthLabel}}</text>
      <text class="header-subtitle">收支记录回顾</text>
    </view>

    <!-- 本月总览 -->
    <view class="account-big">
      <view class="big-row">
        <text class="big-label">收入</text>
        <text class="big-value text-income">¥ {{accountReport.income}}</text>
      </view>
      <view class="big-row">
        <text class="big-label">支出</text>
        <text class="big-value text-expense">¥ {{accountReport.expense}}</text>
      </view>
      <view class="big-row big-balance">
        <text class="big-label">结余</text>
        <text class="big-value">¥ {{accountReport.balance}}</text>
      </view>
    </view>

    <!-- 对比上月 -->
    <view class="section">
      <text class="section-title">对比上月</text>
      <view class="compare-row">
        <view class="compare-col">
          <text class="compare-label">本月收入</text>
          <text class="compare-value text-income">¥ {{accountReport.income}}</text>
        </view>
        <view class="compare-col">
          <text class="compare-label">上月收入</text>
          <text class="compare-value">¥ {{accountReport.incomeLastMonth}}</text>
        </view>
      </view>
      <view class="compare-row">
        <view class="compare-col">
          <text class="compare-label">本月支出</text>
          <text class="compare-value text-expense">¥ {{accountReport.expense}}</text>
        </view>
        <view class="compare-col">
          <text class="compare-label">上月支出</text>
          <text class="compare-value">¥ {{accountReport.expenseLastMonth}}</text>
        </view>
      </view>
    </view>

    <!-- Top3 支出分类 -->
    <view class="section" wx:if="{{accountReport.topCategories.length > 0}}">
      <text class="section-title">Top3 支出分类</text>
      <view class="category-list">
        <view wx:for="{{accountReport.topCategories}}" wx:key="name" class="cat-row">
          <text class="cat-name">{{index + 1}}. {{item.name}}</text>
          <view class="cat-progress">
            <view class="cat-fill expense-fill" style="width: {{item.percent+'%'}}"></view>
          </view>
          <text class="cat-percent">¥ {{item.amount}}</text>
        </view>
      </view>
    </view>

    <!-- 学习投入 -->
    <view class="learn-invest-card" wx:if="{{accountReport.learnInvestment > 0}}">
      <text class="invest-icon">📚</text>
      <view class="invest-info">
        <text class="invest-title">本月学习投入</text>
        <text class="invest-amount">¥ {{accountReport.learnInvestment}}</text>
        <text class="invest-desc">占本月支出 {{accountReport.learnInvestPercent}}%,为自己投资是最划算的</text>
      </view>
    </view>

    <!-- 极值日 -->
    <view class="section">
      <view class="extreme-row">
        <view class="extreme-item">
          <text class="extreme-label">消费最多</text>
          <text class="extreme-date">{{accountReport.maxDay.date}}</text>
          <text class="extreme-amount text-expense">¥ {{accountReport.maxDay.amount}}</text>
        </view>
        <view class="extreme-item">
          <text class="extreme-label">消费最少</text>
          <text class="extreme-date">{{accountReport.minDay.date}}</text>
          <text class="extreme-amount">¥ {{accountReport.minDay.amount}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{accountReport.income == 0 && accountReport.expense == 0}}" class="empty-state">
      <text class="empty-text">本月还没有账单,快去「知时」切换到记账模式记一笔吧</text>
    </view>
  </block>

  <!-- ============== 周期报告 ============== -->
  <block wx:if="{{mode === 'period'}}">
    <view class="report-header">
      <text class="header-title">周期报告</text>
      <text class="header-subtitle">身体状态回顾</text>
    </view>

    <view wx:if="{{!periodReport.hasData}}" class="empty-state">
      <text class="empty-text">还没有记录,连续记录 2 次经期后才能生成分析</text>
    </view>

    <block wx:if="{{periodReport.hasData}}">
      <!-- 平均周期 -->
      <view class="period-big">
        <text class="pb-num">{{periodReport.avgCycle}}</text>
        <text class="pb-label">天 · 平均周期长度</text>
      </view>

      <!-- 最近周期柱状图 -->
      <view class="section" wx:if="{{periodReport.lastCycles.length > 0}}">
        <text class="section-title">最近周期长度</text>
        <view class="trend-chart">
          <view wx:for="{{periodReport.lastCyclesHeight}}" wx:key="index" class="trend-bar-wrap">
            <text class="trend-value">{{periodReport.lastCycles[index]}}</text>
            <view class="trend-bar period-bar" style="height: {{item}}rpx"></view>
            <text class="trend-label">第{{index + 1}}次</text>
          </view>
        </view>
      </view>

      <!-- Top5 症状 -->
      <view class="section" wx:if="{{periodReport.symptomRank.length > 0}}">
        <text class="section-title">出现最多的症状</text>
        <view class="symptom-list">
          <view wx:for="{{periodReport.symptomRank}}" wx:key="name" class="sym-row">
            <text class="sym-rank">{{index + 1}}</text>
            <text class="sym-name">{{item.name}}</text>
            <text class="sym-count">{{item.count}} 次</text>
          </view>
        </view>
      </view>

      <!-- 心情统计 -->
      <view class="section" wx:if="{{periodReport.moodStats.length > 0}}">
        <text class="section-title">心情记录</text>
        <view class="mood-grid">
          <view wx:for="{{periodReport.moodStats}}" wx:key="name" class="mood-item">
            <text class="mood-name">{{item.name}}</text>
            <text class="mood-count">{{item.count}}</text>
          </view>
        </view>
      </view>

      <view class="tip-card">
        <text class="tip-text">温馨提醒:此报告仅供自我了解参考,具体身体状况建议咨询医生</text>
      </view>
    </block>
  </block>

</view>
