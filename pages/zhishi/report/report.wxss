/* pages/zhishi/report/report.wxss */

.report-page {
  background: #FFFFFF;
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 48rpx;
}

.report-header {
  text-align: center;
  padding: 32rpx 0 40rpx;
}
.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
}
.header-subtitle {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* ========== 四格统计 ========== */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.stat-box {
  flex: 1;
  min-width: 45%;
  background: #F7F9FC;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
}
.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6rpx;
}
.stat-label {
  font-size: 22rpx;
  color: #999999;
}
.text-learn { color: #6B9BD8; }
.text-income { color: #7DCE82; }
.text-expense { color: #E57373; }

/* ========== 章节 ========== */
.section {
  background: #FFFFFF;
  border: 1rpx solid #F0F0F0;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

/* ========== 柱状图 ========== */
.trend-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 220rpx;
  padding-top: 20rpx;
}
.trend-bar-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.trend-value {
  font-size: 20rpx;
  color: #999999;
  margin-bottom: 6rpx;
}
.trend-bar {
  width: 48rpx;
  background: linear-gradient(180deg, #6B9BD8 0%, #A3C3E8 100%);
  border-radius: 8rpx 8rpx 0 0;
  min-height: 6rpx;
}
.period-bar {
  background: linear-gradient(180deg, #FF8BA7 0%, #FFC1D0 100%);
}
.trend-label {
  font-size: 20rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* ========== 分类进度条 ========== */
.category-list { }
.cat-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  gap: 16rpx;
}
.cat-name {
  width: 140rpx;
  font-size: 24rpx;
  color: #333333;
  flex-shrink: 0;
}
.cat-progress {
  flex: 1;
  height: 16rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  overflow: hidden;
}
.cat-fill {
  height: 100%;
  background: linear-gradient(90deg, #6B9BD8 0%, #A3C3E8 100%);
  border-radius: 8rpx;
}
.expense-fill {
  background: linear-gradient(90deg, #E57373 0%, #F0A5A5 100%);
}
.cat-percent {
  width: 140rpx;
  text-align: right;
  font-size: 24rpx;
  color: #666666;
  flex-shrink: 0;
}

/* ========== 时段分布 ========== */
.slot-grid {
  display: flex;
  gap: 12rpx;
}
.slot-box {
  flex: 1;
  background: #F7F9FC;
  border-radius: 12rpx;
  padding: 20rpx 8rpx;
  text-align: center;
}
.slot-emoji {
  display: block;
  font-size: 36rpx;
  margin-bottom: 6rpx;
}
.slot-label {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 4rpx;
}
.slot-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #6B9BD8;
}

/* ========== 最高效一天 ========== */
.highlight-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FFF4E6 0%, #FFE8D0 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.highlight-icon {
  font-size: 56rpx;
  margin-right: 20rpx;
}
.highlight-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6rpx;
}
.highlight-desc {
  display: block;
  font-size: 22rpx;
  color: #666666;
}

/* ========== 记账大数字 ========== */
.account-big {
  background: linear-gradient(135deg, #FFF5F7 0%, #FFE8F0 100%);
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 16rpx;
}
.big-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 12rpx 0;
}
.big-balance {
  border-top: 1rpx solid #FFD4DF;
  margin-top: 8rpx;
  padding-top: 20rpx;
}
.big-label {
  font-size: 26rpx;
  color: #666666;
}
.big-value {
  font-size: 40rpx;
  font-weight: 600;
}

/* ========== 对比 ========== */
.compare-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.compare-col {
  flex: 1;
  background: #F7F9FC;
  border-radius: 12rpx;
  padding: 16rpx;
  text-align: center;
}
.compare-label {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 6rpx;
}
.compare-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
}

/* ========== 学习投入 ========== */
.learn-invest-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #E8F1FF 0%, #D0E4FF 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.invest-icon {
  font-size: 56rpx;
  margin-right: 20rpx;
}
.invest-info {
  flex: 1;
}
.invest-title {
  display: block;
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 4rpx;
}
.invest-amount {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #6B9BD8;
  margin-bottom: 4rpx;
}
.invest-desc {
  display: block;
  font-size: 22rpx;
  color: #666666;
}

/* ========== 极值日 ========== */
.extreme-row {
  display: flex;
  gap: 16rpx;
}
.extreme-item {
  flex: 1;
  background: #F7F9FC;
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  text-align: center;
}
.extreme-label {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 6rpx;
}
.extreme-date {
  display: block;
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 6rpx;
}
.extreme-amount {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
}

/* ========== 周期报告大数字 ========== */
.period-big {
  background: linear-gradient(135deg, #FFF5F7 0%, #FFE8F0 100%);
  border-radius: 20rpx;
  padding: 40rpx 24rpx;
  margin-bottom: 16rpx;
  text-align: center;
}
.pb-num {
  display: block;
  font-size: 72rpx;
  font-weight: 600;
  color: #FF8BA7;
}
.pb-label {
  font-size: 24rpx;
  color: #666666;
}

/* ========== 症状排行 ========== */
.symptom-list { }
.sym-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.sym-row:last-child { border-bottom: none; }
.sym-rank {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background: #FFE8F0;
  color: #FF8BA7;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 600;
  margin-right: 16rpx;
}
.sym-name {
  flex: 1;
  font-size: 26rpx;
  color: #333333;
}
.sym-count {
  font-size: 24rpx;
  color: #999999;
}

/* ========== 心情网格 ========== */
.mood-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.mood-item {
  background: #FFE8F0;
  border-radius: 100rpx;
  padding: 12rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.mood-name {
  font-size: 24rpx;
  color: #FF8BA7;
}
.mood-count {
  font-size: 22rpx;
  color: #FF8BA7;
  background: #FFFFFF;
  border-radius: 50%;
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
}

/* ========== 提示卡片 ========== */
.tip-card {
  background: #FFF8F0;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 16rpx;
}
.tip-text {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.6;
}

/* ========== 空状态 ========== */
.empty-state {
  padding: 120rpx 32rpx;
  text-align: center;
}
.empty-text {
  font-size: 26rpx;
  color: #999999;
  line-height: 1.8;
}
