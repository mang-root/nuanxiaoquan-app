<view class="zhishi-page">

<!-- ============== 顶栏（改回下拉框样式）============== -->
<view class="top-bar">
  <view class="top-bar-left">
    <view class="month-nav">
      
      <text class="nav-label">{{viewYear}}年{{viewMonth}}月</text>
      
    </view>
    <view class="top-info-row">
      <text class="top-info-item" wx:if="{{currentMode === 'plan'}}">周{{weekLabel}} · 今日计划 {{planCountToday}}</text>
      <text class="top-info-item" wx:if="{{currentMode === 'account'}}">周{{weekLabel}} · 今日账单 {{accountCountToday}} 笔</text>
      <text class="top-info-item" wx:if="{{currentMode === 'period'}}">周{{weekLabel}} · 关注身体节律</text>
    </view>
  </view>

  <!-- 下拉按钮（和你之前右上角筛选一样） -->
  <view class="mode-btn mode-btn-{{currentMode}}" bindtap="toggleModeSelector">
    <text wx:if="{{currentMode === 'plan'}}">📘 学习计划</text>
    <text wx:if="{{currentMode === 'account'}}">💰 记账</text>
    <text wx:if="{{currentMode === 'period'}}">💗 生理期</text>
    <text class="arrow">▾</text>
  </view>
</view>

<!-- 模式标识色条 -->
<view class="mode-bar mode-bar-{{currentMode}}"></view>

<!-- ============ 学习计划（完全保留你现在的内容）============ -->
<block wx:if="{{currentMode === 'plan'}}">
  <view class="mode-block mode-block-plan">
    <view class="plan-topbar">
      <view class="plan-topbar-left">
        <text class="plan-today-label">{{todayLabel}}</text>
        <text class="plan-progress-text" wx:if="{{planTotalCount > 0}}">
          {{planDoneCount}}/{{planTotalCount}} 已完成
        </text>
      </view>
      <view class="plan-topbar-right">
        <view class="plan-top-btn" bindtap="openHistoryPlan">📖 历史</view>
        <view class="plan-top-btn plan-top-btn-add" bindtap="addBoard">＋ 新板块</view>
      </view>
    </view>

    <view class="plan-progress-bar-wrap" wx:if="{{planTotalCount > 0}}">
      <view class="plan-progress-bar">
        <view class="plan-progress-fill" style="width: {{planTotalCount > 0 ? (planDoneCount / planTotalCount * 100) : 0+'%'}}; background: #6b9bd8;"></view>
      </view>
    </view>

    <view wx:if="{{planBoards.length === 0}}" class="plan-empty">
      <text class="plan-empty-icon">📝</text>
      <text class="plan-empty-text">今天还没有学习计划</text>
      <text class="plan-empty-sub">点上方「＋ 新板块」创建一个</text>
    </view>

    <view wx:for="{{planBoards}}" wx:key="id" wx:for-item="board" wx:for-index="bi" class="plan-board">
      <view class="plan-board-header">
        <view class="plan-board-color-dot" style="background: {{board.color}};" bindtap="openColorPicker" data-boardid="{{board.id}}"></view>
        <input
          class="plan-board-title"
          value="{{board.title}}"
          placeholder="板块名称"
          bindinput="onBoardTitleInput"
          bindblur="onBoardTitleBlur"
          data-boardid="{{board.id}}"
          data-boardindex="{{bi}}"
        />
        <text class="plan-board-count">{{board.doneCount}}/{{board.items.length}}</text>
        <view class="plan-board-del" catchtap="deleteBoard" data-boardid="{{board.id}}">×</view>
      </view>

      <view class="plan-task-list">
        <view
          wx:for="{{board.items}}"
          wx:key="id"
          wx:for-item="task"
          wx:for-index="ti"
          class="plan-task-row {{task.done ? 'done' : ''}}"
          bindtouchstart="onTaskTouchStart"
          bindtouchend="onTaskTouchEnd"
          data-boardid="{{board.id}}"
          data-taskid="{{task.id}}"
          data-done="{{task.done}}"
          data-boardindex="{{bi}}"
        >
          <view
            class="task-circle"
            style="border-color: {{board.color}}; background: {{task.done ? board.color : 'transparent'}};"
            catchtap="toggleTask"
            data-boardid="{{board.id}}"
            data-taskid="{{task.id}}"
          >
            <text wx:if="{{task.done}}" class="task-check-tick">✓</text>
          </view>
          <text class="task-text {{task.done ? 'task-text-done' : ''}}">{{task.text}}</text>
          <view class="task-actions">
            <view
              wx:if="{{bi < planBoards.length - 1}}"
              class="task-act-btn"
              catchtap="moveTaskToNext"
              data-boardid="{{board.id}}"
              data-taskid="{{task.id}}"
              data-boardindex="{{bi}}"
            >→</view>
            <view class="task-act-btn task-del-btn" catchtap="deleteTask" data-boardid="{{board.id}}" data-taskid="{{task.id}}">×</view>
          </view>
        </view>
      </view>

      <view class="plan-add-task-row">
        <view class="task-circle task-circle-add" style="border-color: {{board.color}};"></view>
        <input
          class="plan-add-task-input"
          placeholder="添加任务"
          value="{{addItemInputs[board.id] || ''}}"
          bindinput="onNewItemInput"
          bindconfirm="addTaskToBoard"
          confirm-type="next"
          data-boardid="{{board.id}}"
        />
      </view>

      <view
        wx:if="{{board.doneCount > 0 && bi < planBoards.length - 1}}"
        class="plan-move-done-btn"
        bindtap="moveAllDoneToNext"
        data-boardindex="{{bi}}"
      >
        <text>将 {{board.doneCount}} 个已完成 → 移到下一板块</text>
      </view>
    </view>

    <view class="no-punish-tip">
      <text class="npt-icon">🌱</text>
      <text class="npt-text">暖小圈承诺:计划未完成不扣暖心值、不中断打卡。今天没做到,明天再来就好</text>
    </view>
  </view>
</block>

<!-- ============ 记账（完全保留你现在的内容）============ -->
<block wx:if="{{currentMode === 'account'}}">
  <view class="mode-block mode-block-account">
    <view class="account-card">
      <view class="account-card-head">
        <text class="account-card-label">今日</text>
        <view class="account-add-btn" bindtap="openAccountForm">+ 记一笔</view>
      </view>
      <view class="account-summary">
        <view class="summary-col">
          <text class="summary-val income">+{{accountStats.dayIncome}}</text>
          <text class="summary-lb">收入</text>
        </view>
        <view class="summary-col">
          <text class="summary-val expense">-{{accountStats.dayExpense}}</text>
          <text class="summary-lb">支出</text>
        </view>
        <view class="summary-col">
          <text class="summary-val">{{accountStats.dayBalance}}</text>
          <text class="summary-lb">结余</text>
        </view>
      </view>
    </view>

    <view class="account-card">
      <view class="account-card-head">
        <text class="account-card-label">本月累计</text>
      </view>
      <view class="account-summary">
        <view class="summary-col">
          <text class="summary-val income">+{{accountStats.monthIncome}}</text>
          <text class="summary-lb">收入</text>
        </view>
        <view class="summary-col">
          <text class="summary-val expense">-{{accountStats.monthExpense}}</text>
          <text class="summary-lb">支出</text>
        </view>
      </view>
    </view>

    <view class="account-list-title">今日明细</view>
    <view wx:if="{{accountList.length === 0}}" class="account-empty">
      <text>今天还没记账,点上方「+ 记一笔」开始</text>
    </view>
    <view class="account-list">
      <view wx:for="{{accountList}}" wx:key="id" class="account-item">
        <view class="ai-left">
          <view class="ai-type-dot ai-type-{{item.type}}"></view>
          <view class="ai-info">
            <text class="ai-note">{{item.note}}</text>
            <text class="ai-time">{{item.type === 'income' ? '收入' : '支出'}}</text>
          </view>
        </view>
        <view class="ai-right">
          <text class="ai-amount ai-amount-{{item.type}}">
            {{item.type === 'income' ? '+' : '-'}}{{item.amount}}
          </text>
          <text class="ai-del" catchtap="deleteAccountItem" data-id="{{item.id}}">删除</text>
        </view>
      </view>
    </view>
  </view>
</block>

<!-- ============ 生理期（完全保留你现在的内容）============ -->
<block wx:if="{{currentMode === 'period'}}">
  <view class="mode-block mode-block-period">
    <view wx:if="{{!periodInfo.hasData}}" class="period-tip-empty">
      <text class="tip-emoji">💗</text>
      <text class="tip-text">还没有记录</text>
      <text class="tip-sub">记录 1-2 次后会自动预测下次日期和周期分析</text>
      <view class="btn-primary-period" bindtap="openPeriodRecord">现在开始记录</view>
    </view>

    <view wx:if="{{periodInfo.hasData}}">
      <view class="period-main-card">
        <view class="period-phase-tag">{{periodInfo.phase}} · 第 {{periodInfo.phaseDay}} 天</view>
        <view class="period-big-num" wx:if="{{periodInfo.daysUntilNext > 0}}">
          <text class="pbn-hint">距下次还有</text>
          <text class="pbn-num">{{periodInfo.daysUntilNext}}</text>
          <text class="pbn-hint">天</text>
        </view>
        <view class="period-big-num" wx:elif="{{periodInfo.daysUntilNext === 0}}">
          <text class="pbn-num-sm">预计今天</text>
        </view>
        <view class="period-big-num" wx:else>
          <text class="pbn-hint">已推迟</text>
          <text class="pbn-num">{{-periodInfo.daysUntilNext}}</text>
          <text class="pbn-hint">天</text>
        </view>

        <view wx:if="{{periodInfo.anomalyTip}}" class="anomaly-tip">
          <text>⚠️ {{periodInfo.anomalyTip}}</text>
        </view>
        <view wx:if="{{periodInfo.prePeriodTip}}" class="pre-period-tip">
          <text>🌸 {{periodInfo.prePeriodTip}}</text>
        </view>
      </view>

      <view class="period-today-tip">
        <text class="period-tip-title">今日小贴士</text>
        <text class="period-tip-body">{{periodInfo.todayTip}}</text>
        <text class="period-advice">💡 {{periodInfo.todayAdvice}}</text>
      </view>

      <view class="period-data-row">
        <view class="pd-item">
          <text class="pd-val">{{periodInfo.nextPredict}}</text>
          <text class="pd-label">预测下次</text>
        </view>
        <view class="pd-item">
          <text class="pd-val">{{periodInfo.avgCycle}}天</text>
          <text class="pd-label">平均周期</text>
        </view>
        <view class="pd-item">
          <text class="pd-val">{{periodInfo.avgPeriod}}天</text>
          <text class="pd-label">平均经期</text>
        </view>
      </view>

      <view class="period-ovulation">
        <text class="pov-title">🌸 排卵期预测</text>
        <text class="pov-range">{{periodInfo.ovulationStart}} 至 {{periodInfo.ovulationEnd}}</text>
        <text class="pov-sub">排卵日约 {{periodInfo.ovulationDay}}</text>
      </view>

      <view class="period-actions">
        <view class="btn-primary-period" bindtap="openPeriodRecord">+ 记录今天</view>
      </view>
    </view>

    <view class="period-note">仅供自我了解,具体身体状况请咨询医生</view>
  </view>
</block>

<!-- ============== 下拉选择弹层（和你之前一样）============== -->
<view wx:if="{{modeSelectorShow}}" class="mask" bindtap="toggleModeSelector">
  <view class="mode-selector" catchtap="">
    <view class="ms-item" bindtap="chooseMode" data-mode="plan">
      <text class="ms-icon">📘</text>
      <text class="ms-name">学习计划</text>
      <text wx:if="{{currentMode === 'plan'}}" class="ms-check">✓</text>
    </view>
    <view class="ms-item" bindtap="chooseMode" data-mode="account">
      <text class="ms-icon">💰</text>
      <text class="ms-name">记账</text>
      <text wx:if="{{currentMode === 'account'}}" class="ms-check">✓</text>
    </view>
    <view class="ms-item" wx:if="{{showPeriodMode}}" bindtap="chooseMode" data-mode="period">
      <text class="ms-icon">💗</text>
      <text class="ms-name">生理期</text>
      <text wx:if="{{currentMode === 'period'}}" class="ms-check">✓</text>
    </view>
    <view wx:if="{{!showPeriodMode}}" class="ms-item ms-disabled" bindtap="chooseMode" data-mode="period">
      <text class="ms-icon">💗</text>
      <text class="ms-name">生理期(去开启)</text>
    </view>
  </view>
</view>

<!-- ============== 其他弹层（完全保留）============== -->
<view wx:if="{{planHistoryShow}}" class="mask" bindtap="closeHistoryPlan">
  <view class="sheet" catchtap="">
    <view class="sheet-title">历史计划(点击载入)</view>
    <view wx:for="{{planHistory}}" wx:key="date" class="history-row" bindtap="useHistoryPlan" data-date="{{item.date}}">
      <view class="history-date">{{item.date}}</view>
      <view class="history-preview">{{item.preview}}</view>
      <view class="history-count">共 {{item.count}} 条</view>
    </view>
    <view class="sheet-close" bindtap="closeHistoryPlan">取消</view>
  </view>
</view>

<view wx:if="{{accountFormShow}}" class="mask">
  <view class="sheet" catchtap="">
    <view class="sheet-title">记一笔</view>
    <view class="type-switcher">
      <view class="type-btn {{accountForm.type === 'expense' ? 'active' : ''}}" bindtap="onAccountType" data-type="expense">支出</view>
      <view class="type-btn {{accountForm.type === 'income' ? 'active' : ''}}" bindtap="onAccountType" data-type="income">收入</view>
    </view>
    <view class="amount-input-wrap">
      <text class="amount-unit">¥</text>
      <input
        class="amount-input"
        type="digit"
        placeholder="0.00"
        value="{{accountForm.amount}}"
        bindinput="onAccountAmount"
        focus="{{accountFormShow}}"
      />
    </view>
    <input
      class="note-input"
      placeholder="备注(可不填),如 早餐、地铁"
      value="{{accountForm.note}}"
      bindinput="onAccountNote"
      maxlength="20"
    />
    <view class="sheet-actions">
      <view class="btn-secondary" bindtap="closeAccountForm">取消</view>
      <view class="btn-primary" bindtap="saveAccount">保存</view>
    </view>
  </view>
</view>

<view wx:if="{{periodRecordShow}}" class="mask">
  <view class="sheet" catchtap="">
    <view class="sheet-title">记录今天</view>
    <view class="form-row-col">
      <text class="form-label">流量</text>
      <view class="tag-group">
        <text
          wx:for="{{['无', '少', '中', '多']}}"
          wx:key="*this"
          class="tag {{periodForm.flow === item ? 'tag-active-period' : ''}}"
          bindtap="onPeriodFlow"
          data-val="{{item}}"
        >{{item}}</text>
      </view>
    </view>
    <view class="form-row-col">
      <text class="form-label">经血颜色</text>
      <view class="tag-group">
        <text
          wx:for="{{bloodColorOptions}}"
          wx:key="*this"
          class="tag {{periodForm.bloodColor === item ? 'tag-active-period' : ''}}"
          bindtap="onBloodColorChange"
          data-val="{{item}}"
        >{{item}}</text>
      </view>
      <text class="color-tip">{{bloodColorTips[periodForm.bloodColor]}}</text>
    </view>
    <view class="form-row-col">
      <text class="form-label">疼痛</text>
      <view class="tag-group">
        <text
          wx:for="{{['无', '轻', '中', '重']}}"
          wx:key="*this"
          class="tag {{periodForm.pain === item ? 'tag-active-period' : ''}}"
          bindtap="onPeriodPain"
          data-val="{{item}}"
        >{{item}}</text>
      </view>
    </view>
    <view class="form-row-col" style="margin-top: 16rpx;">
      <text class="form-label">自定义周期(天)</text>
      <view class="cycle-input-row">
        <input
          class="cycle-input"
          type="number"
          value="{{periodCustomCycle}}"
          bindinput="onCustomCycleInput"
          placeholder="21-45"
        />
        <text class="cycle-unit">天(范围 21-45)</text>
      </view>
      <text class="cycle-tip">将以此周期预测下次日期,适配你的个人规律</text>
    </view>
    <view class="form-row-col">
      <text class="form-label">备注</text>
      <textarea
        class="note-textarea"
        placeholder="今天感觉怎么样..."
        value="{{periodForm.note}}"
        bindinput="onPeriodNote"
        maxlength="200"
      ></textarea>
    </view>
    <view class="sheet-actions">
      <view class="btn-secondary" bindtap="closePeriodRecord">取消</view>
      <view class="btn-primary" bindtap="savePeriod">保存</view>
    </view>
  </view>
</view>

<view wx:if="{{colorPickShow}}" class="mask" bindtap="closeColorPicker"></view>
<view wx:if="{{colorPickShow}}" class="sheet" catchtap="">
  <view class="sheet-title">选择板块颜色</view>
  <view class="color-pick-grid">
    <view
      wx:for="{{boardColors}}"
      wx:key="*this"
      class="color-pick-dot {{colorPickCurrentColor === item ? 'selected' : ''}}"
      style="background: {{item}};"
      bindtap="pickColor"
      data-color="{{item}}"
    ></view>
  </view>
</view>


<!-- AI 悬浮按钮（公共组件） -->
<ai-fab></ai-fab>
</view>