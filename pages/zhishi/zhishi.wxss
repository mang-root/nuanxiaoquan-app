/* pages/zhishi/zhishi.wxss */

.zhishi-page {
  background: #ffffff;
  min-height: 100vh;
  padding-bottom: 48rpx;
}

/* ============ 顶栏 ============ */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx 12rpx;
}
.top-bar-left {
  display: flex;
  flex-direction: column;
}
.month-nav {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}
.nav-arrow {
  font-size: 36rpx;
  color: #999;
  padding: 0 8rpx;
}
.nav-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.top-info-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.top-info-item {
  font-size: 22rpx;
  color: #999;
}
.top-info-sep {
  font-size: 22rpx;
  color: #ddd;
}
.mode-btn {
  padding: 10rpx 20rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
}
.mode-btn .arrow {
  margin-left: 6rpx;
  font-size: 22rpx;
}
.mode-btn-plan {
  background: #e8f1ff;
  color: #6b9bd8;
}
.mode-btn-account {
  background: #e8f7e9;
  color: #4caf50;
}
.mode-btn-period {
  background: #ffe8f0;
  color: #ff8da8;
}

.mode-bar {
  height: 6rpx;
  margin: 0 24rpx 24rpx;
  border-radius: 3rpx;
}
.mode-bar-plan { background: #6b9bd8; }
.mode-bar-account { background: #7dce82; }
.mode-bar-period { background: #ff8ba7; }

/* ============ 模式块 ============ */
.mode-block {
  padding: 0 24rpx;
}

/* ============ 记账 ============ */
.account-card {
  background: #f7fbf7;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #e8f7e9;
}
.account-card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.account-card-label {
  font-size: 26rpx;
  color: #666;
  font-weight: 600;
}
.account-add-btn {
  padding: 8rpx 20rpx;
  background: #7dce82;
  color: #ffffff;
  border-radius: 100rpx;
  font-size: 22rpx;
}
.account-summary {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 16rpx 0 8rpx;
}
.summary-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.summary-val {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}
.summary-val.income { color: #7dce82; }
.summary-val.expense { color: #e57373; }
.summary-lb {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

.account-list-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  padding: 24rpx 0 12rpx;
}
.account-empty {
  padding: 60rpx 24rpx;
  text-align: center;
  color: #999;
  font-size: 24rpx;
  background: #fafafa;
  border-radius: 12rpx;
}
.account-list {
  display: flex;
  flex-direction: column;
}
.account-item {
  background: #ffffff;
  border: 1rpx solid #f0f0f0;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.ai-left {
  display: flex;
  align-items: center;
}
.ai-type-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}
.ai-type-income { background: #7dce82; }
.ai-type-expense { background: #e57373; }
.ai-info {
  display: flex;
  flex-direction: column;
}
.ai-note {
  font-size: 28rpx;
  color: #333;
}
.ai-time {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}
.ai-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}
.ai-amount {
  font-size: 28rpx;
  font-weight: 600;
}
.ai-amount-income { color: #7dce82; }
.ai-amount-expense { color: #e57373; }
.ai-del {
  font-size: 20rpx;
  color: #ccc;
  margin-top: 6rpx;
}

/* ============ 生理期 ============ */
.period-tip-empty {
  padding: 80rpx 32rpx;
  background: #fff5f7;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.tip-emoji {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}
.tip-text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 6rpx;
}
.tip-sub {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 32rpx;
  text-align: center;
}

.period-tip-card {
  background: linear-gradient(135deg, #ffe8f0 0%, #fff5f7 100%);
  border-radius: 20rpx;
  padding: 40rpx 24rpx;
  margin-bottom: 16rpx;
}
.period-big-info {
  text-align: center;
  margin-bottom: 32rpx;
}
.pbt-hint {
  font-size: 24rpx;
  color: #666;
  margin: 0 8rpx;
}
.pbt-num {
  font-size: 72rpx;
  font-weight: 600;
  color: #ff8ba7;
  margin: 0 8rpx;
}
.period-small-info {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}
.psi-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #ffe8f0;
}
.psi-row:last-child {
  border-bottom: none;
}
.psi-label {
  font-size: 24rpx;
  color: #999;
}
.psi-val {
  font-size: 26rpx;
  color: #333;
}
.period-actions {
  margin-top: 24rpx;
  display: flex;
  justify-content: center;
}
.btn-primary-period {
  background: #ff8da8;
  color: #ffffff;
  padding: 20rpx 48rpx;
  border-radius: 100rpx;
  font-size: 28rpx;
}
.period-note {
  text-align: center;
  font-size: 20rpx;
  color: #bbb;
  margin-top: 24rpx;
}

/* ============ 遮罩 & 弹层 ============ */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.mode-selector {
  position: fixed;
  top: 110rpx;
  right: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 12rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  width: 280rpx;
}
.ms-item {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  font-size: 28rpx;
  color: #333;
}
.ms-icon {
  margin-right: 16rpx;
  font-size: 32rpx;
}
.ms-name {
  flex: 1;
}
.ms-check {
  color: #ff8da8;
  font-size: 32rpx;
  font-weight: 600;
}
.ms-disabled {
  color: #ccc;
}

.sheet {
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  width: 100%;
  padding: 32rpx;
  max-height: 85vh;
  overflow-y: auto;
}
.sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 24rpx;
}
.sheet-close {
  margin-top: 16rpx;
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 28rpx;
}
.sheet-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}
.btn-primary {
  flex: 1;
  background: #ff8da8;
  color: #ffffff;
  padding: 20rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx;
}
.btn-secondary {
  flex: 1;
  background: #f5f5f5;
  color: #666;
  padding: 20rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx;
}

/* 记账弹层 */
.type-switcher {
  display: flex;
  background: #f5f5f5;
  border-radius: 100rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
}
.type-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 26rpx;
  color: #666;
  border-radius: 100rpx;
}
.type-btn.active {
  background: #ffffff;
  color: #7dce82;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.amount-input-wrap {
  display: flex;
  align-items: center;
  background: #f9fbf9;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #e8f7e9;
}
.amount-unit {
  font-size: 32rpx;
  color: #333;
  margin-right: 8rpx;
}
.amount-input {
  flex: 1;
  font-size: 48rpx;
  font-weight: 300;
  color: #333;
}
.note-input {
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
}
.note-textarea {
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  min-height: 160rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 生理期弹层 */
.form-row-col {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
}
.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}
.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.tag {
  padding: 10rpx 28rpx;
  border-radius: 100rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 24rpx;
}
.tag-active-period {
  background: #ff8da8;
  color: #ffffff;
}

/* 历史计划弹层 */
.history-row {
  padding: 20rpx;
  background: #f9fbff;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid #e8f1ff;
}
.history-date {
  font-size: 24rpx;
  color: #6b9bd8;
  font-weight: 600;
}
.history-preview {
  font-size: 26rpx;
  color: #333;
  margin-top: 8rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.history-count {
  font-size: 20rpx;
  color: #999;
  margin-top: 6rpx;
}

/* === 生理期新样式 === */
.period-main-card {
  background: linear-gradient(135deg, #ffe8f0 0%, #fff5f7 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
  text-align: center;
}
.period-phase-tag {
  display: inline-block;
  background: #ff8da8;
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 100rpx;
  margin-bottom: 20rpx;
}
.period-big-num {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}
.pbn-hint { font-size: 24rpx; color: #666; }
.pbn-num { font-size: 80rpx; font-weight: 600; color: #ff8ba7; line-height: 1; }
.pbn-num-sm { font-size: 40rpx; font-weight: 600; color: #ff8ba7; }
.anomaly-tip {
  background: #fff3e0;
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
  font-size: 22rpx;
  color: #e8943a;
  text-align: left;
  margin-top: 12rpx;
}
.pre-period-tip {
  background: #fce4ec;
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
  font-size: 22rpx;
  color: #e91e8c;
  text-align: left;
  margin-top: 12rpx;
}
.period-today-tip {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #ffe8f0;
}
.period-tip-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #ff8da8;
  margin-bottom: 10rpx;
}
.period-tip-body {
  display: block;
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 10rpx;
}
.period-advice {
  display: block;
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}
.period-data-row {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #f0f0f0;
}
.pd-item {
  flex: 1;
  text-align: center;
}
.pd-val {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}
.pd-label {
  display: block;
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}
.period-ovulation {
  background: #f0e6ff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}
.pov-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #8e44ad;
  margin-bottom: 8rpx;
}
.pov-range {
  display: block;
  font-size: 26rpx;
  color: #333;
  margin-bottom: 4rpx;
}
.pov-sub {
  display: block;
  font-size: 22rpx;
  color: #888;
}

/* ===== 学习计划新样式 ===== */
.plan-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0 12rpx;
  margin-bottom: 8rpx;
}
.plan-topbar-left {
  display: flex;
  flex-direction: column;
}
.plan-today-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}
.plan-progress-text {
  font-size: 22rpx;
  color: #6b9bd8;
  margin-top: 4rpx;
}
.plan-topbar-right {
  display: flex;
  gap: 12rpx;
  align-items: center;
}
.plan-top-btn {
  font-size: 22rpx;
  color: #6b9bd8;
  background: #e8f1ff;
  padding: 8rpx 16rpx;
  border-radius: 100rpx;
}
.plan-top-btn-add {
  background: #6b9bd8;
  color: #fff;
}

.plan-progress-bar-wrap {
  margin-bottom: 20rpx;
}
.plan-progress-bar {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}
.plan-progress-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s;
}

.plan-empty {
  padding: 80rpx 0;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.plan-empty-icon { font-size: 72rpx; margin-bottom: 12rpx; }
.plan-empty-text { font-size: 28rpx; color: #666; margin-bottom: 6rpx; }
.plan-empty-sub { font-size: 22rpx; color: #999; }

/* 板块卡片 */
.plan-board {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.plan-board-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 12rpx;
}
.plan-board-color-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.plan-board-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  padding: 0;
  background: transparent;
}
.plan-board-count {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
}
.plan-board-del {
  font-size: 36rpx;
  color: #ccc;
  padding: 0 4rpx;
  flex-shrink: 0;
}

/* 任务行 */
.plan-task-list {
  margin-bottom: 12rpx;
}
.plan-task-row {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  gap: 16rpx;
  transition: background 0.15s;
}
.plan-task-row:last-child {
  border-bottom: none;
}
.plan-task-row.done {
  opacity: 0.6;
}

/* 圆形勾选框 */
.task-circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}
.task-check-tick {
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}
.task-circle-add {
  border-style: dashed;
  background: transparent;
}

/* 任务文字 */
.task-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  word-break: break-all;
}
.task-text-done {
  text-decoration: line-through;
  color: #999;
}

/* 右侧操作按钮 */
.task-actions {
  display: flex;
  gap: 8rpx;
  align-items: center;
  flex-shrink: 0;
}
.task-act-btn {
  padding: 4rpx 12rpx;
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  border-radius: 8rpx;
}
.task-del-btn {
  color: #e57373;
  background: #ffeaea;
}

/* 新增任务输入行 */
.plan-add-task-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0 4rpx;
}
.plan-add-task-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  background: #f7f7f7;
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
}

/* 移动已完成按钮 */
.plan-move-done-btn {
  margin-top: 16rpx;
  padding: 14rpx;
  background: #f0f6ff;
  border-radius: 10rpx;
  text-align: center;
  color: #6b9bd8;
  font-size: 24rpx;
  border: 1rpx dashed #6b9bd8;
}

/* 颜色选择弹层 */
.color-pick-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: center;
  padding: 16rpx 0;
}
.color-pick-dot {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
}
.color-pick-dot.selected {
  box-shadow: 0 0 0 4rpx #fff, 0 0 0 7rpx #333;
}

/* 无惩罚提示 */
.no-punish-tip {
  display: flex;
  align-items: flex-start;
  background: #f7faff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 8rpx;
  border-left: 6rpx solid #6b9bd8;
}
.npt-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.npt-text {
  font-size: 22rpx;
  color: #666;
  line-height: 1.7;
}

/* 新增：经期颜色 & 自定义周期样式 */
.color-tip {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}
.cycle-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
}
.cycle-input {
  width: 120rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  font-size: 28rpx;
  text-align: center;
}
.cycle-unit {
  font-size: 22rpx;
  color: #999;
}
.cycle-tip {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 6rpx;
}