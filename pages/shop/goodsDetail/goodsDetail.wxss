/* pages/shop/goodsDetail/goodsDetail.wxss */

.detail-page {
  background: #FFFFFF;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

.author-bar {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.avatar-letter {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
}
.author-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.author-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}
.author-level {
  font-size: 22rpx;
  color: #FF8DA8;
  margin-top: 4rpx;
}

.image-swiper {
  width: 100%;
  background: #F5F5F5;
}
.swiper-img {
  width: 100%;
  height: 100%;
}

.content-area {
  padding: 24rpx;
}
.res-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  line-height: 1.4;
  margin-bottom: 16rpx;
}
.res-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.tag {
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  background: #F5F5F5;
  color: #666666;
}
.tag-learn {
  background: #E8F1FF;
  color: #6B9BD8;
}
.res-stats {
  font-size: 22rpx;
  color: #999999;
}
.res-content {
  display: block;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  white-space: pre-wrap;
  margin-bottom: 24rpx;
}
.res-time {
  font-size: 22rpx;
  color: #999999;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx 32rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #F0F0F0;
}
.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 24rpx;
}
.action-icon {
  font-size: 40rpx;
  color: #666666;
}
.action-icon.active {
  color: #FF8DA8;
}
.action-label {
  font-size: 20rpx;
  color: #999999;
  margin-top: 2rpx;
}
.free-tip {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: #999999;
}

.empty-state {
  padding: 200rpx 0;
  text-align: center;
}
.empty-text {
  color: #999999;
  font-size: 26rpx;
}
