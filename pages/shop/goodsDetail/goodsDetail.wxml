<!-- pages/shop/goodsDetail/goodsDetail.wxml -->
<view class="detail-page">

  <view wx:if="{{!resource}}" class="empty-state">
    <text class="empty-text">资源不存在或已删除</text>
  </view>

  <block wx:if="{{resource}}">
    <!-- 作者 -->
    <view class="author-bar">
      <view class="avatar" style="background: {{resource.authorAvatarColor || '#FFD4DF'}};">
        <text class="avatar-letter">{{resource.authorNickname ? resource.authorNickname.substring(0,1) : '同'}}</text>
      </view>
      <view class="author-info">
        <text class="author-name">{{resource.authorNickname}}</text>
        <text class="author-level">{{resource.authorLevelName || '新序'}}</text>
      </view>
    </view>

    <!-- 图片 -->
    <swiper wx:if="{{resource.images && resource.images.length > 0}}" class="image-swiper" indicator-dots="{{resource.images.length > 1}}" autoplay="{{false}}" circular="{{false}}" style="height: 560rpx;">
      <swiper-item wx:for="{{resource.images}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" class="swiper-img" bindtap="previewImage" data-url="{{item}}" />
      </swiper-item>
    </swiper>

    <!-- 正文 -->
    <view class="content-area">
      <text class="res-title">{{resource.title}}</text>

      <view class="res-meta">
        <text class="tag tag-learn">{{resource.category}}</text>
        <text class="res-stats">{{resource.collectCount || 0}} 收藏</text>
      </view>

      <text class="res-content">{{resource.content}}</text>

      <text class="res-time">{{createdTime}}</text>
    </view>

    <!-- 底部固定栏 -->
    <view class="bottom-bar">
      <view class="action-btn" bindtap="toggleCollect">
        <text class="action-icon {{resource.collected ? 'active' : ''}}">{{resource.collected ? '★' : '☆'}}</text>
        <text class="action-label">{{resource.collected ? '已收藏' : '收藏'}}</text>
      </view>
      <view class="action-btn" bindtap="reportResource">
        <text class="action-icon">⚐</text>
        <text class="action-label">举报</text>
      </view>
      <view class="free-tip">
        <text>免费学习资源 · 仅供交流</text>
      </view>
    </view>
  </block>

</view>
