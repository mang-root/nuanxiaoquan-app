/* pages/shop/shop.wxss */

.shop-page {
  background: #FFFFFF;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 搜索 */
.top-search {
  padding: 16rpx 24rpx;
  background: #FFFFFF;
}
.search-box {
  display: flex;
  align-items: center;
  background: #F5F5F5;
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
  height: 64rpx;
}
.search-icon {
  font-size: 26rpx;
  margin-right: 12rpx;
  color: #999999;
}
.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333333;
}
.search-clear {
  color: #CCCCCC;
  font-size: 36rpx;
  padding: 0 8rpx;
}

/* 分类 */
.category-bar {
  white-space: nowrap;
  padding: 12rpx 12rpx 16rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F5F5F5;
}
.cat-item {
  display: inline-block;
  padding: 10rpx 24rpx;
  margin-right: 12rpx;
  font-size: 24rpx;
  color: #666666;
  background: #F5F5F5;
  border-radius: 100rpx;
}
.cat-item.active {
  background: #FF8DA8;
  color: #FFFFFF;
  font-weight: 600;
}

/* 瀑布流 */
.waterfall {
  flex: 1;
  padding: 16rpx 12rpx 0;
  background: #FFFFFF;
}
.columns {
  display: flex;
  gap: 12rpx;
}
.column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.res-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid #F0F0F0;
}
.rc-cover image {
  width: 100%;
  display: block;
}
.rc-cover-placeholder {
  width: 100%;
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cover-emoji {
  font-size: 120rpx;
}
.cover-0 { background: linear-gradient(135deg, #FFE8F0 0%, #FFD4DF 100%); }
.cover-1 { background: linear-gradient(135deg, #E8F1FF 0%, #D4E4FF 100%); }
.cover-2 { background: linear-gradient(135deg, #FFF5E6 0%, #FFE8D0 100%); }
.cover-3 { background: linear-gradient(135deg, #E8F7E9 0%, #D4EDD6 100%); }
.cover-4 { background: linear-gradient(135deg, #F0E6FF 0%, #E0D4FF 100%); }
.rc-content {
  padding: 16rpx;
}
.rc-title {
  display: block;
  font-size: 26rpx;
  color: #333333;
  line-height: 1.4;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.rc-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.rc-author {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}
.mini-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 8rpx;
  flex-shrink: 0;
}
.mini-letter {
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 600;
}
.author-name {
  font-size: 22rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.collect-btn {
  display: flex;
  align-items: center;
  padding: 4rpx 8rpx;
}
.collect-icon {
  font-size: 28rpx;
  color: #FF8DA8;
  margin-right: 4rpx;
}
.collect-count {
  font-size: 22rpx;
  color: #999999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
}
.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}
.empty-text {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 8rpx;
}
.empty-sub {
  font-size: 22rpx;
  color: #999999;
}

/* 悬浮按钮 */
.fab-publish {
  position: fixed;
  right: 32rpx;
  bottom: 48rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF8DA8 0%, #FFA8BC 100%);
  box-shadow: 0 8rpx 24rpx rgba(255, 141, 168, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}
.fab-icon {
  color: #FFFFFF;
  font-size: 56rpx;
  font-weight: 300;
  line-height: 1;
}

/* 发布弹层 */
.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
}
.publish-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1001;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  width: 100%;
  padding: 32rpx;
  max-height: 90vh;
  overflow-y: auto;
  box-sizing: border-box;
}
.sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}
.sheet-close {
  font-size: 48rpx;
  color: #999999;
}
.form-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.form-row-col {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
}
.form-label {
  width: 140rpx;
  font-size: 26rpx;
  color: #666666;
  flex-shrink: 0;
}
.form-row-col .form-label {
  width: auto;
  margin-bottom: 12rpx;
}
.input-base {
  flex: 1;
  background: #F7F7F7;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
}
.textarea-base {
  background: #F7F7F7;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  width: 100%;
  min-height: 240rpx;
}
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.img-item {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}
.img-item image {
  width: 100%;
  height: 100%;
}
.img-del {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(0,0,0,0.5);
  color: #FFFFFF;
  font-size: 28rpx;
}
.img-add {
  width: 180rpx;
  height: 180rpx;
  border: 2rpx dashed #CCCCCC;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.img-add-plus {
  font-size: 56rpx;
  color: #CCCCCC;
  font-weight: 300;
}
.form-tip {
  font-size: 22rpx;
  color: #999999;
  margin-top: 12rpx;
}
.form-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}
.form-actions .btn-primary,
.form-actions .btn-secondary {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}
.btn-primary {
  background: #FF8DA8;
  color: #FFFFFF;
}
.btn-secondary {
  background: #F5F5F5;
  color: #666666;
}
.placeholder {
  color: #999;
}
/* 资源卡片分类标签 */
.res-cate {
  display: inline-block;
  font-size: 22rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin: 16rpx 16rpx 0 16rpx;
}
/* 限制分类文字 */
.pub-cate-tip {
  font-size: 20rpx;
  color: #f5a623;
  padding: 4rpx 0 12rpx;
}