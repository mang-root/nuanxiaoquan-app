.profile-page { background: #FAFAFA; min-height: 100vh; }
.profile-top {
  display: flex; align-items: center; gap: 20rpx;
  background: linear-gradient(180deg, #FFE8F0 0%, #FFF5F7 100%);
  padding: 80rpx 24rpx 32rpx;
}
.profile-avatar {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  border: 3rpx solid #FF8DA8; flex-shrink: 0;
}
.profile-letter { font-size: 40rpx; color: #fff; font-weight: 700; }
.profile-info { flex: 1; display: flex; flex-direction: column; gap: 8rpx; }
.profile-name { font-size: 32rpx; font-weight: 700; color: #333; }
.level-badge { font-size: 22rpx; color: #FF8DA8; background: #FFF0F4; padding: 4rpx 12rpx; border-radius: 20rpx; }
.profile-sign { font-size: 24rpx; color: #888; }
.edit-btn { background: #FF8DA8; color: #fff; font-size: 24rpx; padding: 10rpx 24rpx; border-radius: 30rpx; }

.stats-row {
  display: flex; background: #fff;
  padding: 24rpx 0; margin-bottom: 16rpx;
}
.stat-col {
  flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6rpx;
  border-right: 1rpx solid #F0F0F0;
}
.stat-col:last-child { border-right: none; }
.stat-n { font-size: 36rpx; font-weight: 700; color: #333; }
.stat-l { font-size: 22rpx; color: #999; }

.empty-tips {
  background: #FFF5F7; margin: 16rpx; border-radius: 16rpx; padding: 24rpx;
}
.tips-text { font-size: 26rpx; color: #FF8DA8; }

.other-notice {
  display: flex; align-items: center; justify-content: center;
  padding: 80rpx 40rpx;
}
.notice-text { font-size: 28rpx; color: #999; }
