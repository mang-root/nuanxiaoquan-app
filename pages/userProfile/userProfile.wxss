.profile-page {
  background: #fff;
  min-height: 100vh;
}

/* 顶部 */
.profile-top {
  background: linear-gradient(135deg, #ffe8f0 0%, #fff5f7 100%);
  padding: 60rpx 32rpx 40rpx;
  display: flex;
  align-items: center;
}
.profile-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  border: 4rpx solid #fff;
  flex-shrink: 0;
}
.profile-letter {
  color: #fff;
  font-size: 48rpx;
  font-weight: 600;
}
.profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.profile-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}
.profile-level {
  margin-bottom: 8rpx;
}
.level-badge {
  font-size: 22rpx;
  color: #ff8da8;
  background: rgba(255,255,255,0.8);
  padding: 4rpx 16rpx;
  border-radius: 100rpx;
}
.profile-sign {
  font-size: 24rpx;
  color: #666;
}
.edit-btn {
  padding: 12rpx 24rpx;
  border: 1rpx solid #ff8da8;
  color: #ff8da8;
  border-radius: 100rpx;
  font-size: 24rpx;
  flex-shrink: 0;
}

/* 数据行 */
.stats-row {
  display: flex;
  padding: 24rpx 16rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.stat-col {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-n {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}
.stat-l {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* Tab */
.tabs {
  display: flex;
  padding: 0 24rpx;
  background: #fff;
  border-bottom: 2rpx solid #f0f0f0;
}
.tab {
  padding: 24rpx 32rpx;
  font-size: 26rpx;
  color: #999;
  position: relative;
  margin-right: 16rpx;
}
.tab.active {
  color: #333;
  font-weight: 600;
}
.tab.active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #ff8da8;
  border-radius: 2rpx;
}

/* 内容区 */
.content-area {
  padding: 16rpx 24rpx;
}
.card-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.card {
  background: #f9f9f9;
  border-radius: 16rpx;
  padding: 24rpx;
}
.card:active {
  background: #f0f0f0;
}
.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.card-content {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.card-imgs {
  display: flex;
  gap: 8rpx;
  margin-bottom: 12rpx;
}
.card-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #eee;
}
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.card-tag {
  font-size: 22rpx;
  color: #6b9bd8;
  background: #e8f1ff;
  padding: 4rpx 12rpx;
  border-radius: 100rpx;
}
.card-stat {
  font-size: 22rpx;
  color: #999;
}

.empty {
  padding: 120rpx 0;
  text-align: center;
}
.empty-text {
  font-size: 26rpx;
  color: #999;
}