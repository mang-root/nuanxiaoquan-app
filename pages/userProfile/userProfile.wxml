<view class="profile-page">

<!-- 顶部信息区 -->
<view class="profile-top">
  <view class="profile-avatar" style="background: {{profile.avatarColor}};">
    <text class="profile-letter">{{profile.nickname ? profile.nickname.substring(0,1) : '同'}}</text>
  </view>

  <view class="profile-info">
    <text class="profile-name">{{profile.nickname}}</text>
    <view class="profile-level" bindtap="gotoLevel">
      <text class="level-badge">Lv.{{profile.level}} · {{profile.levelName}}</text>
    </view>
    <text wx:if="{{profile.signature}}" class="profile-sign">{{profile.signature}}</text>
  </view>

  <view wx:if="{{isSelf}}" class="edit-btn" bindtap="editProfile">编辑资料</view>
</view>

<!-- 数据统计(精简) -->
<view class="stats-row">
  <view class="stat-col">
    <text class="stat-n">{{stats.studyDays}}</text>
    <text class="stat-l">学习天</text>
  </view>
  <view class="stat-col">
    <text class="stat-n">{{stats.totalMinutes}}</text>
    <text class="stat-l">专注分钟</text>
  </view>
  <view class="stat-col">
    <text class="stat-n">{{profile.heartValue || 0}}</text>
    <text class="stat-l">暖心值</text>
  </view>
</view>

<view class="empty-tips" wx:if="{{isSelf}}">
  <text class="tips-text">🔒 私密笔记仅自己可见，去「我的」页面查看</text>
</view>

<view wx:if="{{!isSelf}}" class="other-notice">
  <text class="notice-text">👤 该用户暂无公开内容</text>
</view>

<view style="height: 60rpx;"></view>
</view>
