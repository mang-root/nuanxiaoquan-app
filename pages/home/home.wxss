/* pages/home/home.wxss */
page { background: #faf9f7; }
.container { padding: 0 0 140rpx; min-height: 100vh; }

/* 顶部栏 */
.top-bar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 54rpx 32rpx 18rpx;
  background: #fff;
}
.top-left { display: flex; align-items: center; gap: 10rpx; }
.top-logo { font-size: 34rpx; }
.top-title { font-size: 36rpx; font-weight: 700; color: #2d2d2d; letter-spacing: 2rpx; }
.checkin-btn {
  background: #f5f5f5; border-radius: 32rpx;
  padding: 10rpx 26rpx; font-size: 26rpx; color: #888;
}
.checkin-btn.checked { background: #FFE8EE; color: #FF8DA8; font-weight: 600; }

/* 每日语录 */
.quote-card {
  margin: 20rpx 24rpx 0;
  background: linear-gradient(135deg, #fff5f8 0%, #fff9f0 100%);
  border-radius: 24rpx; padding: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(255,141,168,0.10);
}
.quote-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18rpx; }
.quote-tag { display: flex; align-items: center; gap: 8rpx; }
.quote-dot { font-size: 20rpx; color: #FF8DA8; }
.quote-tag-text { font-size: 22rpx; color: #FF8DA8; font-weight: 600; }
.quote-date-badge { font-size: 22rpx; color: #bbb; background: #fff; border-radius: 20rpx; padding: 4rpx 16rpx; }
.quote-text { font-size: 30rpx; color: #3a3a3a; line-height: 1.8; font-style: italic; display: block; }
.quote-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 18rpx; }
.quote-author { font-size: 24rpx; color: #bbb; }
.quote-refresh { width: 48rpx; height: 48rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: #FF8DA8; }
.spin { display: inline-block; animation: spin 1s linear infinite; }
@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

/* 打卡历史 */
.history-section { margin: 24rpx 0 0; }
.section-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 32rpx; margin-bottom: 16rpx;
}
.section-title { font-size: 28rpx; font-weight: 700; color: #2d2d2d; }
.section-title-wrap { display: flex; align-items: baseline; gap: 10rpx; }
.section-sub { font-size: 22rpx; color: #bbb; }
.section-more { font-size: 24rpx; color: #FF8DA8; }
.history-scroll { padding-left: 32rpx; }
.history-row { display: flex; gap: 16rpx; padding-right: 32rpx; width: max-content; }
.history-item { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.history-bubble {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.history-mood { font-size: 20rpx; color: #555; }
.history-date { font-size: 20rpx; color: #bbb; }

/* 快捷入口 */
.quick-grid {
  display: flex; justify-content: space-around;
  margin: 24rpx 24rpx 0;
  background: #fff; border-radius: 20rpx; padding: 28rpx 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.quick-item { display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.quick-icon-wrap {
  width: 88rpx; height: 88rpx; border-radius: 24rpx;
  display: flex; align-items: center; justify-content: center;
}
.quick-icon { font-size: 40rpx; }
.quick-label { font-size: 22rpx; color: #666; }

/* 热门资源横滑 */
.loading-tip, .empty-tip { text-align: center; padding: 40rpx 0; color: #ccc; font-size: 26rpx; }
.empty-emoji { display: block; font-size: 48rpx; margin-bottom: 12rpx; }
.empty-text { font-size: 26rpx; color: #ccc; }

.hot-scroll { padding-left: 32rpx; }
.hot-row { display: flex; gap: 20rpx; padding-right: 32rpx; width: max-content; }
.hot-card {
  width: 280rpx; background: #fff; border-radius: 20rpx;
  overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.07);
  flex-shrink: 0;
}
.hot-card-cover {
  width: 100%; height: 200rpx;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.hot-cover-img { width: 100%; height: 100%; }
.hot-cover-emoji { font-size: 72rpx; }
.cover-0 { background: linear-gradient(135deg, #FFE8F0, #FFD4DF); }
.cover-1 { background: linear-gradient(135deg, #E8F1FF, #D4E4FF); }
.cover-2 { background: linear-gradient(135deg, #FFF5E6, #FFE8D0); }
.cover-3 { background: linear-gradient(135deg, #E8F7E9, #D4EDD6); }
.cover-4 { background: linear-gradient(135deg, #F0E6FF, #E0D4FF); }
.hot-card-body { padding: 16rpx; }
.hot-cate-tag {
  display: inline-block; font-size: 20rpx; color: #FF8DA8;
  background: #fff5f8; border-radius: 8rpx; padding: 3rpx 12rpx; margin-bottom: 10rpx;
}
.hot-title {
  display: block; font-size: 26rpx; font-weight: 600; color: #2d2d2d;
  line-height: 1.4; margin-bottom: 10rpx;
  overflow: hidden; text-overflow: ellipsis; display: -webkit-box;
  -webkit-box-orient: vertical; -webkit-line-clamp: 2;
}
.hot-meta { display: flex; gap: 16rpx; }
.hot-click, .hot-collect { font-size: 22rpx; color: #bbb; }

/* 今日概览 */
.summary-card {
  margin: 24rpx 24rpx 0; background: #fff; border-radius: 20rpx;
  padding: 28rpx 32rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.summary-title { font-size: 26rpx; color: #aaa; display: block; margin-bottom: 18rpx; }
.summary-row { display: flex; align-items: center; }
.summary-item { flex: 1; text-align: center; }
.summary-num { font-size: 48rpx; font-weight: 700; color: #FF8DA8; display: block; }
.summary-label { font-size: 22rpx; color: #aaa; display: block; margin-top: 4rpx; }
.summary-divider { width: 1rpx; height: 64rpx; background: #f0f0f0; }

/* 打卡弹层 */
.mask { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 200; }
.checkin-sheet {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff; border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx 60rpx; z-index: 201;
}
.checkin-title { font-size: 32rpx; font-weight: 700; color: #2d2d2d; text-align: center; }
.checkin-sub { font-size: 24rpx; color: #aaa; text-align: center; margin: 12rpx 0 28rpx; }
.mood-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 16rpx; }
.mood-btn { border-radius: 16rpx; padding: 24rpx 0; text-align: center; }
.mood-label { font-size: 26rpx; color: #444; }
