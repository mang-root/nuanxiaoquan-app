<view class="container">

<!-- 顶部栏 -->
<view class="top-bar">
  <view class="top-left">
    <text class="top-logo">🌸</text>
    <text class="top-title">暖小圈</text>
  </view>
  <view class="checkin-btn {{todayMood ? 'checked' : ''}}" bindtap="openCheckin">
    <text>{{todayMood ? todayMood + ' ✓' : '今日打卡'}}</text>
  </view>
</view>

<!-- 每日语录卡 -->
<view class="quote-card">
  <view class="quote-top">
    <view class="quote-tag">
      <text class="quote-dot">✦</text>
      <text class="quote-tag-text">每日语录</text>
    </view>
    <text class="quote-date-badge">{{todayMood ? '已打卡 ✓' : '未打卡'}}</text>
  </view>
  <text class="quote-text">"{{dailyQuote.text}}"</text>
  <view class="quote-footer">
    <text class="quote-author">— {{dailyQuote.author}}</text>
    <view class="quote-refresh" bindtap="refreshQuote">
      <text class="{{quoteLoading ? 'spin' : ''}}">↻</text>
    </view>
  </view>
</view>

<!-- 打卡历史条（最近7天） -->
<view class="history-section" wx:if="{{checkinHistory.length > 0}}">
  <view class="section-head">
    <text class="section-title">打卡记录</text>
    <text class="section-more" bindtap="gotoCheckinHistory">全部 ›</text>
  </view>
  <scroll-view class="history-scroll" scroll-x="true" show-scrollbar="false">
    <view class="history-row">
      <view class="history-item" wx:for="{{checkinHistory}}" wx:key="date">
        <view class="history-bubble" style="background: {{item.mood === '愉悦' ? '#ffe8ee' : item.mood === '平静' ? '#f5f1eb' : item.mood === '低落' ? '#e8f2fb' : item.mood === '焦虑' ? '#f3eafb' : item.mood === '专注' ? '#e8f8f6' : '#f5f5f5'}};">
          <text class="history-mood">{{item.mood}}</text>
        </view>
        <text class="history-date">{{item.dayLabel}}</text>
      </view>
    </view>
  </scroll-view>
</view>

<!-- 快捷入口 4个 -->
<view class="quick-grid">
  <view class="quick-item" bindtap="gotoShop">
    <view class="quick-icon-wrap" style="background:#fff5f8;">
      <text class="quick-icon">📚</text>
    </view>
    <text class="quick-label">学习资源</text>
  </view>
  <view class="quick-item" bindtap="gotoAI">
    <view class="quick-icon-wrap" style="background:#fff8ee;">
      <text class="quick-icon">✨</text>
    </view>
    <text class="quick-label">AI小暖</text>
  </view>
  <view class="quick-item" bindtap="gotoCheckinHistory">
    <view class="quick-icon-wrap" style="background:#eef5ff;">
      <text class="quick-icon">📆</text>
    </view>
    <text class="quick-label">打卡历史</text>
  </view>
  <view class="quick-item" bindtap="gotoZhishi">
    <view class="quick-icon-wrap" style="background:#eefaf2;">
      <text class="quick-icon">📓</text>
    </view>
    <text class="quick-label">知时</text>
  </view>
</view>

<!-- 热门资源 -->
<view class="section-head" style="margin: 28rpx 32rpx 16rpx;">
  <view class="section-title-wrap">
    <text class="section-title">🔥 热门资源</text>
    <text class="section-sub">按点击量排序</text>
  </view>
  <text class="section-more" bindtap="gotoShop">更多 ›</text>
</view>

<view wx:if="{{hotResourcesLoading}}" class="loading-tip">
  <text>加载中…</text>
</view>

<view wx:if="{{!hotResourcesLoading && hotResources.length === 0}}" class="empty-tip">
  <text class="empty-emoji">📚</text>
  <text class="empty-text">小馆资源即将更新，敬请期待</text>
</view>

<!-- 横滑卡片 -->
<scroll-view wx:if="{{hotResources.length > 0}}" class="hot-scroll" scroll-x="true" show-scrollbar="false">
  <view class="hot-row">
    <view
      class="hot-card"
      wx:for="{{hotResources}}"
      wx:key="id"
      bindtap="gotoResourceDetail"
      data-id="{{item.id}}"
    >
      <view class="hot-card-cover cover-{{item.id % 5}}">
        <image wx:if="{{item.images && item.images.length > 0}}" src="{{item.images[0]}}" mode="aspectFill" class="hot-cover-img" />
        <text wx:else class="hot-cover-emoji">{{item.category === '笔记' ? '📝' : item.category === '资料' ? '📚' : item.category === '心得' ? '💡' : '📖'}}</text>
      </view>
      <view class="hot-card-body">
        <text class="hot-cate-tag">{{item.category}}</text>
        <text class="hot-title">{{item.title}}</text>
        <view class="hot-meta">
          <text class="hot-click">👁 {{item.clickCount || 0}}</text>
          <text class="hot-collect">★ {{item.collectCount || 0}}</text>
        </view>
      </view>
    </view>
  </view>
</scroll-view>

<!-- 今日学习小结 -->
<view class="summary-card" wx:if="{{todaySummary.totalMin > 0 || todaySummary.streak > 0}}">
  <text class="summary-title">今日概览</text>
  <view class="summary-row">
    <view class="summary-item">
      <text class="summary-num">{{todaySummary.totalMin}}</text>
      <text class="summary-label">学习分钟</text>
    </view>
    <view class="summary-divider"></view>
    <view class="summary-item">
      <text class="summary-num">{{todaySummary.streak}}</text>
      <text class="summary-label">连续打卡</text>
    </view>
  </view>
</view>

<!-- AI 悬浮按钮（公共组件） -->
<ai-fab></ai-fab>

<!-- 情绪打卡弹层 -->
<view wx:if="{{checkinShow}}" class="mask" catchtap="closeCheckin"></view>
<view wx:if="{{checkinShow}}" class="checkin-sheet" catchtap="">
  <view class="checkin-title">今日打卡</view>
  <view class="checkin-sub">选一个最符合你现在状态的词</view>
  <view class="mood-grid">
    <view
      wx:for="{{moodList}}"
      wx:key="label"
      class="mood-btn"
      style="background: {{item.color}};"
      bindtap="selectMood"
      data-label="{{item.label}}"
    >
      <text class="mood-label">{{item.label}}</text>
    </view>
  </view>
</view>

</view>
