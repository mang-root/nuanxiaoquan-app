<view class="container">
  <!-- 顶部栏：左侧 最新/热门 + 右侧 时间筛选 -->
  <view class="top-bar">
    <view class="tab-switch">
      <text class="tab {{tabType=='new'?'on':''}}" bindtap="switchTab" data-type="new">最新</text>
      <text class="tab {{tabType=='hot'?'on':''}}" bindtap="switchTab" data-type="hot">热门</text>
    </view>
    <view class="filter-btn" bindtap="showFilter">筛选</view>
  </view>

  <!-- 横向分类标签 -->
  <scroll-view class="cate-scroll" scroll-x="true" show-scrollbar="false">
    <view class="cate {{cate==index?'on':''}}"
      wx:for="{{cateList}}" wx:key="index"
      bindtap="switchCate" data-index="{{index}}">
      {{item}}
    </view>
  </scroll-view>

  <!-- 动态列表 -->
  <view class="list">
    <view class="card" wx:for="{{list}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view class="user-bar" bindtap="goUser" data-userid="{{item.userId}}" capture-catch:tap="true">
        <view class="avatar"></view>
        <view class="info">
          <text class="name">{{item.nickname}}</text>
          <text class="level">LV.{{item.level}}</text>
        </view>
      </view>
      <view class="content">{{item.content}}</view>
      <view class="action">
        <view class="like"><text>👍 {{item.like}}</text></view>
        <view class="comment"><text>💬 {{item.comment}}</text></view>
      </view>
    </view>
  </view>

  <!-- 筛选弹窗 -->
  <view class="mask" wx:if="{{showFilter}}" bindtap="closeFilter"></view>
  <view class="filter-panel" wx:if="{{showFilter}}">
    <view class="item" bindtap="setFilter" data-day="1">近1天</view>
    <view class="item" bindtap="setFilter" data-day="3">近3天</view>
    <view class="item" bindtap="setFilter" data-day="30">近1月</view>
    <view class="item" bindtap="setFilter" data-day="180">近半年</view>
    <view class="item" bindtap="setFilter" data-day="365">近1年</view>
  </view>
</view>