/* 默认女生主题(粉色) */
page {
  --brand: #ff8da8;
  --brand-light: #ffe8f0;
  --brand-btn: #ff8da8;
  --accent: #ff8da8;
  --tag-bg: #fff0f4;
  --tab-active: #ff8da8;
  --level-bar: #ff8da8;
  --mode-plan-bg: #e8f1ff;
  --mode-plan-color: #6b9bd8;
}

/* 男生主题(低饱和浅蓝) */
page.theme-male {
  --brand: #5b8db8;
  --brand-light: #e8f1fa;
  --brand-btn: #5b8db8;
  --accent: #5b8db8;
  --tag-bg: #eaf2fb;
  --tab-active: #5b8db8;
  --level-bar: #5b8db8;
  --mode-plan-bg: #e8f1fa;
  --mode-plan-color: #5b8db8;
}

/* app.wxss (根目录) */
page {
  background-color: #FFFFFF;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333333;
}

:root {
  --brand-pink: #FF8DA8;
  --study-blue: #6B9BD8;
  --income-green: #7DCE82;
  --expense-red: #E57373;
  --period-pink: #FFD4DF;
  --ovulation-purple: #E0D4FF;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --border-color: #EEEEEE;
}

.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  background-color: var(--brand-pink);
  color: #FFFFFF;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-default {
  background-color: #F5F5F5;
  color: #333333;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
}

.mt-20 { margin-top: 20rpx; }
.mb-20 { margin-bottom: 20rpx; }
.ml-20 { margin-left: 20rpx; }
.mr-20 { margin-right: 20rpx; }
.p-20 { padding: 20rpx; }

.text-ellipsis-1 {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}